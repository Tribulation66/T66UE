				{
					"Namespace": "HeroQuotes",
					"Children": [
						{
							"Source": {
								"Text": "\"Bite back.\""
							},
							"Translation": {
								"Text": "\"Zakousni se.\""
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "\"Catch me first.\""
							},
							"Translation": {
								"Text": "\"Chyť mě první.\""
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "\"Cold wins.\""
							},
							"Translation": {
								"Text": "\"Zima vítězí.\""
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "\"Directive: survive.\""
							},
							"Translation": {
								"Text": "\"Směrnice: přežít.\""
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "\"Embrace the venom.\""
							},
							"Translation": {
								"Text": "\"Udělejme to ošklivé.\""
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "\"Fast hands, faster kill.\""
							},
							"Translation": {
								"Text": "\"Rychlé ruce, rychlejší zabití.\""
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "\"For honor.\""
							},
							"Translation": {
								"Text": "\"Bouře poslouchá.\""
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "\"Gold outlasts gods.\""
							},
							"Translation": {
								"Text": "\"Zlato překoná bohy.\""
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "\"Hold the line.\""
							},
							"Translation": {
								"Text": "\"Držte linii.\""
							},
							"Key": "Hero_1"
						},
						{
							"Source": {
								"Text": "\"It gets worse.\""
							},
							"Translation": {
								"Text": "\"Je to ještě horší.\""
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "\"Kneel to thunder.\""
							},
							"Translation": {
								"Text": "\"Poklekni k hromu.\""
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "\"Send it.\""
							},
							"Translation": {
								"Text": "\"Pošli to.\""
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "\"Stay sharp.\""
							},
							"Translation": {
								"Text": "\"Zůstaň ve střehu.\""
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "\"Strike true.\""
							},
							"Translation": {
								"Text": "\"Break before me.\""
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "\"Unlucky for them.\""
							},
							"Translation": {
								"Text": "\"Neštěstí pro ně.\""
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "\"You won't see dawn.\""
							},
							"Translation": {
								"Text": "\"Neuvidíš svítání.\""
							},
							"Key": "Hero_11"
						}
					]
				},
				{
					"Namespace": "HeroSelection",
					"Children": [
						{
							"Source": {
								"Text": "Base Stats"
							},
							"Translation": {
								"Text": "Základní údaje"
							},
							"Key": "BaseStatsHeader"
