				{
					"Namespace": "HeroDescriptions",
					"Children": [
						{
							"Source": {
								"Text": "A chaos-fueled duelist who wins fights by overwhelming the room."
							},
							"Translation": {
								"Text": "Một nhà độc tài đầy hỗn loạn người chiến thắng bằng cách bao vây căn phòng."
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "A cold-eyed wanderer hardened by long roads and worse winters."
							},
							"Translation": {
								"Text": "Một kẻ lang thang mắt lạnh cứng rắn bởi những con đường dài và mùa đông tồi tệ hơn."
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "A deadpan menace who walks into disaster without blinking."
							},
							"Translation": {
								"Text": "Một mối đe dọa chết người bước vào thảm họa mà không chớp mắt."
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "A disciplined duelist with a steady hand and colder nerve."
							},
							"Translation": {
								"Text": "Một nhân viên kỷ luật với bàn tay vững vàng và thần kinh lạnh hơn."
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "A grim scavenger king draped in dust, gold, and bad omens."
							},
							"Translation": {
								"Text": "Một vị vua tàn ác ăn xác thối trùm trong cát bụi, vàng và điềm xấu."
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "A loyal brawler who charges first and doubts later."
							},
							"Translation": {
								"Text": "Một kẻ hiếu chiến trung thành cáo buộc trước và sau này."
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "A nimble trickster who never stays where danger lands."
							},
							"Translation": {
								"Text": "Một kẻ xảo quyệt không bao giờ ở nơi nguy hiểm."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "A quick-draw outlaw who turns panic into momentum."
							},
							"Translation": {
								"Text": "Một tên cướp nhanh chóng biến hoảng loạn thành động lực."
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "A relentless machine built to keep marching through the swarm."
							},
							"Translation": {
								"Text": "Một cỗ máy không ngừng được xây dựng để tiếp tục diễu hành trong đàn."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "A silent hunter who lets the dark speak for him."
							},
							"Translation": {
								"Text": "Một thợ săn im lặng để bóng tối nói thay cho hắn."
							},
							"Key": "Hero_11"
						},
						{
							"Source": {
								"Text": "A storm-crowned tyrant who fights like thunder made flesh."
							},
							"Translation": {
								"Text": "Một tên bạo chúa nổi tiếng với cơn bão chiến đấu như tiếng sấm đã tạo ra thịt."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "A stubborn survivor who drags every doomed run across the line."
							},
							"Translation": {
								"Text": "Một người sống sót cứng đầu kéo mọi cái chết vượt qua ranh giới."
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "DOT and evasion. Poison and strike."
							},
							"Translation": {
								"Text": "Một kẻ tàn sát theo đường phố sẽ phát triển mạnh khi cuộc chiến trở nên hỗn loạn."
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "Fast bouncer. Chains to multiple foes."
							},
							"Translation": {
								"Text": "Một lãnh chúa phá vỡ ranh giới của kẻ thù thông qua một lực lượng tuyệt đối."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "Select a hero to view their description."
							},
							"Translation": {
								"Text": "Chọn một anh hùng để xem mô tả của họ."
							},
							"Key": "SelectHeroPrompt"
						},
						{
							"Source": {
								"Text": "Steadfast knight. Ready for battle."
							},
							"Translation": {
								"Text": "Một pháp sư già bình tĩnh giấu đi sức mạnh đáng sợ."
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "Sturdy frontline. Favors armor."
							},
							"Translation": {
								"Text": "Mặt trận vững chắc. Áo giáp tốt."
							},
							"Key": "Hero_1"
						}
					]
				},
