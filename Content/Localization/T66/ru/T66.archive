				{
					"Namespace": "Settings",
					"Children": [
						{
							"Source": {
								"Text": "0 disables dithering. Higher values push more of the imported UE5RFX PS1 dither pattern."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1DitherBody"
						},
						{
							"Source": {
								"Text": "0-100"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GameplayNumericHint"
						},
						{
							"Source": {
								"Text": "0-100"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPercentHint"
						},
						{
							"Source": {
								"Text": "APPLY"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXApply"
						},
						{
							"Source": {
								"Text": "AUDIO"
							},
							"Translation": {
								"Text": "Аудио"
							},
							"Key": "TabAudio"
						},
						{
							"Source": {
								"Text": "Adds extra character-space noise on top of snapping. Keep it lower if you want readable combat silhouettes."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexNoiseBody"
						},
						{
							"Source": {
								"Text": "Adds extra world-position noise on top of snapping for rougher retro surfaces."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldVertexNoiseBody"
						},
						{
							"Source": {
								"Text": "Blends character UVs into the affine mapping path. Push this carefully to avoid readability loss in combat."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineBlendBody"
						},
						{
							"Source": {
								"Text": "Blends world UVs into the affine mapping path. 0 keeps stable UVs, 100 fully commits to the retro perspective error."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldAffineBlendBody"
						},
						{
							"Source": {
								"Text": "Borderless Windowed"
							},
							"Translation": {
								"Text": "Безграничное окно"
							},
							"Key": "BorderlessWindowed"
						},
						{
							"Source": {
								"Text": "CONTROLS"
							},
							"Translation": {
								"Text": "Контроли"
							},
							"Key": "TabControls"
						},
						{
							"Source": {
								"Text": "CRASHING"
							},
							"Translation": {
								"Text": "треск"
							},
							"Key": "TabCrashing"
						},
						{
							"Source": {
								"Text": "Character Affine Blend"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineBlendLabel"
						},
						{
							"Source": {
								"Text": "Character Affine Distance 1"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineD1Label"
						},
						{
							"Source": {
								"Text": "Character Affine Distance 2"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineD2Label"
						},
						{
							"Source": {
								"Text": "Character Affine Distance 3"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineD3Label"
						},
						{
							"Source": {
								"Text": "Character Geometry"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXSectionCharacterGeometry"
						},
						{
							"Source": {
								"Text": "Character Geometry Enable"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterGeometryEnableLabel"
						},
						{
							"Source": {
								"Text": "Character Vertex Noise"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexNoiseLabel"
						},
						{
							"Source": {
								"Text": "Character Vertex Snap Resolution"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexSnapResLabel"
						},
						{
							"Source": {
								"Text": "Character Vertex Snap Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexSnapLabel"
						},
						{
							"Source": {
								"Text": "Chromatic Aberration And Pixelation"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXSectionChromatic"
						},
						{
							"Source": {
								"Text": "Chromatic Aberration Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticStrengthLabel"
						},
						{
							"Source": {
								"Text": "Controls how thick the UE5RFX fog becomes once fog is enabled."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogDensityBody"
						},
						{
							"Source": {
								"Text": "Controls the radial RGB split strength for the custom chromatic-aberration post-process pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticStrengthBody"
						},
						{
							"Source": {
								"Text": "Controls the radial screen distortion strength used by the chromatic-aberration pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticDistortionBody"
						},
						{
							"Source": {
								"Text": "Controls the strength of the gameplay haze from 0 to 100. 0 disables native fog entirely, 100 is intentionally very heavy."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "NativeFogIntensityBody"
						},
						{
							"Source": {
								"Text": "Defaults restored."
							},
							"Translation": {
								"Text": "Дефолты восстановлены."
							},
							"Key": "DefaultsRestored"
						},
						{
							"Source": {
								"Text": "Distortion Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticDistortionLabel"
						},
						{
							"Source": {
								"Text": "Drives the existing T66 pixelation subsystem from 0 to full strength."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPixelationBody"
						},
						{
							"Source": {
								"Text": "Enable Media Viewer (TikTok / YouTube Shorts)"
							},
							"Translation": {
								"Text": "Включить просмотр медиа (TikTok / YouTube Shorts)"
							},
							"Key": "MediaViewerEnable"
						},
						{
							"Source": {
								"Text": "Enables or disables the fake UV resolution switch."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResUVBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the fake screen-size resolution switch."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResSizeBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the imported UE5RFX color LUT stage. Color Boost only shows when this is enabled."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1ColorLUTBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the low-fake-resolution path used by the N64 blur pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXN64LowResBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the visible PS1 fog contribution by gating its density."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogBody"
						},
						{
							"Source": {
								"Text": "Enter a value from 0 to 100."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GameplayNumericHelp"
						},
						{
							"Source": {
								"Text": "Enter a value from 0 to 100."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXNumericHint"
						},
						{
							"Source": {
								"Text": "Fake Resolution Size Switch"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResSizeLabel"
						},
						{
							"Source": {
								"Text": "Fake Resolution UV Switch"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResUVLabel"
						},
						{
							"Source": {
								"Text": "Far-distance threshold for character affine mapping. 50 matches the imported sample default."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineD3Body"
						},
						{
							"Source": {
								"Text": "Far-distance threshold for world affine mapping. 50 matches the imported sample default."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldAffineD3Body"
						},
						{
							"Source": {
								"Text": "Flips the radial distortion direction used by the chromatic-aberration pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticInvertBody"
						},
						{
							"Source": {
								"Text": "Fog"
							},
							"Translation": {
								"Text": "туман"
							},
							"Key": "Fog"
						},
						{
							"Source": {
								"Text": "Fullscreen"
							},
							"Translation": {
								"Text": "Полный экран"
							},
							"Key": "Fullscreen"
						},
						{
							"Source": {
								"Text": "GAMEPLAY"
							},
							"Translation": {
								"Text": "Гамеплей"
							},
							"Key": "TabGameplay"
						},
						{
							"Source": {
								"Text": "GRAPHICS"
							},
							"Translation": {
								"Text": "ГРАФИКА"
							},
							"Key": "TabGraphics"
						},
						{
							"Source": {
								"Text": "HUD"
							},
							"Translation": {
								"Text": "ГУД"
							},
							"Key": "TabHUD"
						},
						{
							"Source": {
								"Text": "Higher values drive the target height lower, which makes the scene feel more aggressively low-res."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXTargetResBody"
						},
						{
							"Source": {
								"Text": "Higher values increase the blur sample count in the N64 pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXN64StepsBody"
						},
						{
							"Source": {
								"Text": "Higher values lower the target snap resolution, making hero and enemy geometry wobble more aggressively."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexSnapResBody"
						},
						{
							"Source": {
								"Text": "Higher values lower the target snap resolution, making the world wobble and step more aggressively."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldVertexSnapResBody"
						},
						{
							"Source": {
								"Text": "Higher values pull the fog closer to the camera for a heavier retro atmosphere."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogStartBody"
						},
						{
							"Source": {
								"Text": "Higher values push the imported UE5RFX PS1 sample toward a stronger LUT color boost."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1ColorBoostBody"
						},
