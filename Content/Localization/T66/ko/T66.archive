								"Text": "Character Vertex Snap Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexSnapLabel"
						},
						{
							"Source": {
								"Text": "Chromatic Aberration And Pixelation"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXSectionChromatic"
						},
						{
							"Source": {
								"Text": "Chromatic Aberration Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticStrengthLabel"
						},
						{
							"Source": {
								"Text": "Controls how thick the UE5RFX fog becomes once fog is enabled."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogDensityBody"
						},
						{
							"Source": {
								"Text": "Controls the radial RGB split strength for the custom chromatic-aberration post-process pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticStrengthBody"
						},
						{
							"Source": {
								"Text": "Controls the radial screen distortion strength used by the chromatic-aberration pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticDistortionBody"
						},
						{
							"Source": {
								"Text": "Controls the strength of the gameplay haze from 0 to 100. 0 disables native fog entirely, 100 is intentionally very heavy."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "NativeFogIntensityBody"
						},
						{
							"Source": {
								"Text": "Defaults restored."
							},
							"Translation": {
								"Text": "기본값 복원."
							},
							"Key": "DefaultsRestored"
						},
						{
							"Source": {
								"Text": "Distortion Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticDistortionLabel"
						},
						{
							"Source": {
								"Text": "Drives the existing T66 pixelation subsystem from 0 to full strength."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPixelationBody"
						},
						{
							"Source": {
								"Text": "Enable Media Viewer (TikTok / YouTube Shorts)"
							},
							"Translation": {
								"Text": "사용 가능한 미디어 뷰어 (TikTok / YouTube Shorts)"
							},
							"Key": "MediaViewerEnable"
						},
						{
							"Source": {
								"Text": "Enables or disables the fake UV resolution switch."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResUVBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the fake screen-size resolution switch."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResSizeBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the imported UE5RFX color LUT stage. Color Boost only shows when this is enabled."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1ColorLUTBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the low-fake-resolution path used by the N64 blur pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXN64LowResBody"
						},
						{
							"Source": {
