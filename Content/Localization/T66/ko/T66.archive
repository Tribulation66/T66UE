								"Text": "Unlimited"
							},
							"Translation": {
								"Text": "제한 없음"
							},
							"Key": "Unlimited"
						},
						{
							"Source": {
								"Text": "Uses the missing UE5RFX sample runtime helper path by lowering actual screen percentage and forcing low-quality upscale. This is the strongest shared-resolution mode."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXRealLowResBody"
						},
