						},
						{
							"Source": {
								"Text": "AUDIO"
							},
							"Translation": {
								"Text": "퀵메뉴"
							},
							"Key": "TabAudio"
						},
						{
							"Source": {
								"Text": "Adds extra character-space noise on top of snapping. Keep it lower if you want readable combat silhouettes."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexNoiseBody"
						},
						{
							"Source": {
								"Text": "Adds extra world-position noise on top of snapping for rougher retro surfaces."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldVertexNoiseBody"
						},
						{
							"Source": {
								"Text": "Blends character UVs into the affine mapping path. Push this carefully to avoid readability loss in combat."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineBlendBody"
						},
						{
							"Source": {
								"Text": "Blends world UVs into the affine mapping path. 0 keeps stable UVs, 100 fully commits to the retro perspective error."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldAffineBlendBody"
						},
						{
							"Source": {
								"Text": "Borderless Windowed"
							},
							"Translation": {
								"Text": "Borderless 창"
							},
							"Key": "BorderlessWindowed"
						},
