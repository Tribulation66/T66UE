				{
					"Namespace": "CompanionLore",
					"Children": [
						{
							"Source": {
								"Text": "A cunning trickster with a heart of gold."
							},
							"Translation": {
								"Text": "금의 심장을 가진 멋진 경주."
							},
							"Key": "Companion_05"
						},
						{
							"Source": {
								"Text": "A mysterious companion."
							},
							"Translation": {
								"Text": "신비한 동반자."
							},
							"Key": "Unknown"
						},
						{
							"Source": {
								"Text": "A steadfast guardian who never leaves your side."
							},
							"Translation": {
								"Text": "당신의 측을 결코 떠나지 않는 steadfast 보호자."
							},
							"Key": "Companion_01"
						},
						{
							"Source": {
								"Text": "Born in flames, she heals through sheer willpower."
							},
							"Translation": {
								"Text": "불꽃에서 태어난 그녀는 sheer willpower를 통해 치유합니다."
							},
							"Key": "Companion_02"
						},
						{
							"Source": {
								"Text": "Draws strength from moonlight to shield allies."
							},
							"Translation": {
								"Text": "달빛의 힘은 allies를 보호하기 위하여."
							},
							"Key": "Companion_06"
						},
						{
							"Source": {
								"Text": "Forged in the depths, tempered by tribulation."
							},
							"Translation": {
								"Text": "깊이에서 위조, 삼관에 의해 부드럽게."
							},
							"Key": "Companion_07"
						},
						{
							"Source": {
								"Text": "Loner Style"
							},
							"Translation": {
								"Text": "Loner 스타일"
							},
							"Key": "NoCompanion"
						},
						{
							"Source": {
								"Text": "No lore available."
							},
							"Translation": {
								"Text": "이용안내"
							},
							"Key": "FallbackLore"
						},
						{
							"Source": {
								"Text": "Once a wanderer, now sworn to protect the fallen."
							},
							"Translation": {
								"Text": "방황을 한 번, 이제 방황을 보호하기 위해."
							},
							"Key": "Companion_03"
						},
						{
							"Source": {
								"Text": "The last of her kind, fighting to survive."
							},
							"Translation": {
								"Text": "그녀의 종의 마지막, 생존에 싸움."
							},
							"Key": "Companion_08"
						},
