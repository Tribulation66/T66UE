				{
					"Namespace": "HeroQuotes",
					"Children": [
						{
							"Source": {
								"Text": "\"Bite back.\""
							},
							"Translation": {
								"Text": "\"عودة\""
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "\"Catch me first.\""
							},
							"Translation": {
								"Text": "\"امسكني أولا\""
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "\"Cold wins.\""
							},
							"Translation": {
								"Text": "\"البيع يفوز\""
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "\"Directive: survive.\""
							},
							"Translation": {
								"Text": "\"الانتقائية: البقاء\"."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "\"Embrace the venom.\""
							},
							"Translation": {
								"Text": "\"لنجعلها قبيحة\""
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "\"Fast hands, faster kill.\""
							},
							"Translation": {
								"Text": "\"الأيدي السفلى، قتل أسرع\""
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "\"For honor.\""
							},
							"Translation": {
								"Text": "\"العاصفة تطيع\""
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "\"Gold outlasts gods.\""
							},
							"Translation": {
								"Text": "\"الآلهة القديمة\""
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "\"Hold the line.\""
							},
							"Translation": {
								"Text": "\"أغلق الخط\""
							},
							"Key": "Hero_1"
						},
						{
							"Source": {
								"Text": "\"It gets worse.\""
							},
							"Translation": {
								"Text": "\"يزداد الأمر سوءاً\""
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "\"Kneel to thunder.\""
							},
							"Translation": {
								"Text": "\"اقترب من الرعد\""
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "\"Send it.\""
							},
							"Translation": {
								"Text": "\"ارسله\""
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "\"Stay sharp.\""
							},
							"Translation": {
								"Text": "\"كن حاداً\""
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "\"Strike true.\""
							},
							"Translation": {
								"Text": "\"أزحف أمامي\""
							},
							"Key": "Hero_3"
						},
						{
