				{
					"Namespace": "CompanionLore",
					"Children": [
						{
							"Source": {
								"Text": "A cunning trickster with a heart of gold."
							},
							"Translation": {
								"Text": "مخادع مع قلب من الذهب"
							},
							"Key": "Companion_05"
						},
						{
							"Source": {
								"Text": "A mysterious companion."
							},
							"Translation": {
								"Text": "رفيق غامض"
							},
							"Key": "Unknown"
						},
						{
							"Source": {
								"Text": "A steadfast guardian who never leaves your side."
							},
							"Translation": {
								"Text": "وصي قوي لا يترك جانبك"
							},
							"Key": "Companion_01"
						},
						{
							"Source": {
								"Text": "Born in flames, she heals through sheer willpower."
							},
							"Translation": {
								"Text": "وُلدت في النيران، تلتئم من خلال قوة الوصية."
							},
							"Key": "Companion_02"
						},
						{
							"Source": {
								"Text": "Draws strength from moonlight to shield allies."
							},
							"Translation": {
								"Text": "يسحب القوة من ضوء القمر إلى حماية الحلفاء"
							},
							"Key": "Companion_06"
						},
						{
							"Source": {
								"Text": "Forged in the depths, tempered by tribulation."
							},
							"Translation": {
								"Text": "مُنشأة في الأعماق، مُتقلبة بـ \"تريب\"."
							},
							"Key": "Companion_07"
						},
						{
							"Source": {
								"Text": "Loner Style"
							},
							"Translation": {
								"Text": "Loner Style"
							},
							"Key": "NoCompanion"
						},
						{
							"Source": {
								"Text": "No lore available."
							},
							"Translation": {
								"Text": "لا يوجد مكان"
							},
							"Key": "FallbackLore"
						},
						{
							"Source": {
								"Text": "Once a wanderer, now sworn to protect the fallen."
							},
							"Translation": {
								"Text": "عندما يتجول، أقسم الآن على حماية السقوط."
							},
							"Key": "Companion_03"
						},
						{
							"Source": {
								"Text": "The last of her kind, fighting to survive."
							},
							"Translation": {
								"Text": "آخر نوع من نوعها يقاتل من أجل النجاة"
							},
							"Key": "Companion_08"
						},
						{
							"Source": {
								"Text": "Whispers ancient prayers that mend broken bones."
							},
							"Translation": {
								"Text": "الصلاة القديمة التي تصلح العظام المكسورة"
							},
							"Key": "Companion_04"
						}
					]
				},
