				{
					"Namespace": "StatTooltips",
					"Children": [
						{
							"Source": {
								"Text": "A unique casino token that improves item sell prices. Higher levels push the sell rate up to 100%."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GamblerToken"
						},
						{
							"Source": {
								"Text": "Aggro generation multiplier. Higher values draw more enemy attention."
							},
							"Translation": {
								"Text": "Aggro generáció szorzó. A magasabb értékek több ellenséges figyelmet keltenek."
							},
							"Key": "Taunt"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Támadás sebesség bónusz a hatása alatt álló támadások."
							},
							"Key": "AoeSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Támadás sebesség bónusz ugráló lövedék támadások."
							},
							"Key": "BounceSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Támadás sebesség bónusz a károkozás-over-time hatások."
							},
							"Key": "DotSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Támadás sebesség bónusz piercing támadások."
							},
							"Key": "PierceSpeed"
						},
						{
							"Source": {
								"Text": "Base damage dealt by each attack. Increased by items and level-ups."
							},
							"Translation": {
								"Text": "Minden egyes támadás során keletkezett alapkár. Emelkedett a tételek és a szintek."
							},
							"Key": "Damage"
						},
						{
							"Source": {
								"Text": "Bonus damage for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Bónusz kár a \"area-of-efefect\" támadásokra."
							},
							"Key": "AoeDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Bonus kár pattogó lövedék támadások."
							},
							"Key": "BounceDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for damage-over-time effects."
							},
							"Translation": {
								"Text": "Bónusz kár a kár- over- time hatások miatt."
							},
							"Key": "DotDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for piercing attacks that pass through enemies."
							},
							"Translation": {
								"Text": "Bónusz kár az ellenségeken áthaladó támadásért."
							},
							"Key": "PierceDamage"
						},
						{
							"Source": {
								"Text": "Bonus movement speed multiplier from secondary stat sources."
							},
							"Translation": {
								"Text": "Bónusz mozgás sebesség szorzó másodlagos stat források."
							},
							"Key": "MovementSpeed"
						},
						{
							"Source": {
								"Text": "Chance for each attack to land a critical hit."
							},
							"Translation": {
								"Text": "Minden támadásra van esély, hogy kritikus csapást érjünk el."
							},
							"Key": "CritChance"
						},
						{
							"Source": {
								"Text": "Chance to completely dodge an incoming attack. Also unlocks evasion-based secondary stats."
							},
							"Translation": {
								"Text": "A lehetőség, hogy elkerüljük a közelgő támadást. Is szabadul evasion- alapú másodlagos statisztikák."
							},
							"Key": "Evasion"
						},
						{
							"Source": {
								"Text": "Chance to confuse enemies on hit, making them lose track of you."
							},
							"Translation": {
								"Text": "Esély, hogy összezavarja az ellenséget, hogy elveszítse a nyomát."
							},
							"Key": "Invisibility"
						},
						{
							"Source": {
								"Text": "Chance to counter-attack when dodging an enemy's attack."
							},
							"Translation": {
								"Text": "Esély az ellentámadásra, ha elkerüljük az ellenség támadását."
							},
							"Key": "CounterAttack"
						},
						{
							"Source": {
								"Text": "Chance to encounter a gold-dropping goblin."
							},
							"Translation": {
								"Text": "Esély, hogy találkozzon egy aranydobáló manóval."
							},
							"Key": "Goblin"
						},
						{
							"Source": {
								"Text": "Chance to encounter a leprechaun with bonus rewards."
							},
							"Translation": {
								"Text": "Esély, hogy találkozzon egy kobold bónuszokkal."
							},
							"Key": "Leprechaun"
						},
						{
							"Source": {
								"Text": "Chance to find a Fountain of Life that restores health."
							},
							"Translation": {
								"Text": "Esély megtalálni az Élet Forrását, ami helyreállítja az egészséget."
							},
							"Key": "Fountain"
						},
						{
							"Source": {
								"Text": "Chance to find a bonus spin wheel on the map."
							},
							"Translation": {
								"Text": "Esély, hogy megtalálja a bónusz spinning kerék a térképen."
							},
							"Key": "SpinWheel"
						},
						{
							"Source": {
								"Text": "Chance to find a treasure chest on the map."
							},
							"Translation": {
								"Text": "Esély, hogy találjunk egy kincsesládát a térképen."
							},
							"Key": "TreasureChest"
						},
						{
							"Source": {
								"Text": "Chance to heal when dealing damage to enemies."
							},
							"Translation": {
								"Text": "Esély, hogy meggyógyuljon, ha kárt okoz az ellenségnek."
							},
							"Key": "LifeSteal"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when reflecting damage."
							},
							"Translation": {
								"Text": "Esély, hogy azonnal megöljön egy ellenséget, ha a kárt tükrözi."
							},
							"Key": "Crush"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when you dodge their attack."
							},
							"Translation": {
								"Text": "Esély, hogy azonnal megöljön egy ellenséget, amikor elkerüli a támadást."
							},
							"Key": "Assassinate"
						},
						{
							"Source": {
								"Text": "Chance to reflect incoming damage back at the attacker."
							},
							"Translation": {
								"Text": "Esély, hogy tükrözze a bejövő károkat a támadónál."
							},
							"Key": "ReflectDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier applied on critical hits. 1.5 = 50% bonus damage."
							},
							"Translation": {
								"Text": "Kritikus találat esetén a kár szorzója. 1,5 = 50% -os bónuszkár."
							},
							"Key": "CritDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at close range."
							},
							"Translation": {
								"Text": "A kár szorzója, ha közelről támadják meg az ellenséget."
							},
							"Key": "CloseRangeDmg"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at long range."
							},
							"Translation": {
								"Text": "A kár szorzója, ha hosszú távon támadják az ellenséget."
							},
							"Key": "LongRangeDmg"
						},
						{
							"Source": {
								"Text": "Health points regenerated per second."
							},
							"Translation": {
								"Text": "Az egészségügyi pontok másodpercenként regenerálódnak."
							},
							"Key": "HpRegen"
						},
						{
							"Source": {
								"Text": "Hero movement speed multiplier. Higher values let you move faster across the map."
							},
							"Translation": {
								"Text": "Hős mozgás sebesség szorzó. A magasabb értékek lehetővé teszik, hogy gyorsabban haladj a térképen."
							},
							"Key": "Speed"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Hitbox nagyságú bónusz az effektus elleni támadásokhoz."
							},
							"Key": "AoeScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Hitbox méret bónusz pattogó lövedék támadások."
							},
							"Key": "BounceScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Hitbox méretbónusz a károkozás-over-time hatásokért."
							},
							"Key": "DotScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Hitbox méretű bónusz piercing támadások."
							},
							"Key": "PierceScale"
						},
						{
							"Source": {
								"Text": "How quickly your hero attacks. Higher values reduce the interval between attacks."
							},
							"Translation": {
								"Text": "Milyen gyorsan támad a hősöd. A magasabb értékek csökkentik a támadások közötti távolságot."
							},
							"Key": "AttackSpeed"
						},
						{
							"Source": {
								"Text": "Improves chances for rare item drops, spin-wheel bonuses, and world event spawns."
							},
							"Translation": {
								"Text": "Javítja az esélyeket a ritka termékek csepp, spin-wheel bónuszok, és a világ esemény ívók."
							},
							"Key": "Luck"
						},
						{
							"Source": {
								"Text": "Improves the odds of higher-rarity rewards when opening a crate."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "LootCrate"
						},
						{
							"Source": {
								"Text": "Maximum distance your attacks can reach."
							},
							"Translation": {
								"Text": "Maximális távolság, amit a támadások elérhetnek."
							},
							"Key": "AttackRange"
						},
						{
							"Source": {
								"Text": "Reduces incoming damage from all sources. Each point subtracts flat damage before HP loss."
							},
							"Translation": {
								"Text": "Csökkenti a bejövő károkat minden forrásból. Minden egyes pont levonja a lapos károsodást a HP veszteség előtt."
							},
							"Key": "Armor"
						},
						{
							"Source": {
								"Text": "Size multiplier for your attack hitbox. Larger scale hits more enemies per swing."
							},
							"Translation": {
								"Text": "Méret szorzó a támadáshoz. Nagyobb skálán több ellenséget talál egy hintában."
							},
							"Key": "AttackScale"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to cheat at the Gambler."
							},
							"Translation": {
								"Text": "Sikeres esély, ha megpróbálsz csalni a Szerencsejátékban."
							},
							"Key": "Cheating"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to steal from the Vendor."
							},
							"Translation": {
								"Text": "Sikeres esély, ha megpróbálsz lopni a Vendortól."
							},
							"Key": "Stealing"
						},
						{
							"Source": {
								"Text": "Your hero's current level. Gain XP by killing enemies to level up and improve your stats."
							},
							"Translation": {
								"Text": "A hősöd jelenlegi szintje. Gain XP azáltal, hogy megöli az ellenséget, hogy a szintet, és javítsa a statisztikákat."
							},
							"Key": "Level"
						}
					]
				},
