{
	"FormatVersion": 2,
	"Namespace": "",
	"Subnamespaces": [
		{
			"Namespace": "T66",
			"Subnamespaces": [
				{
					"Namespace": "Abilities",
					"Children": [
						{
							"Source": {
								"Text": "AOE attacks that hit 3+ enemies deal 20% bonus damage. Hitting 5+ enemies increases the bonus to 35%."
							},
							"Translation": {
								"Text": "AOE támadások hit 3 + ellenség foglalkozik 20% bónusz kár. Az 5 + ellenségek megütése 35% -ra növeli a bónuszt."
							},
							"Key": "PassiveDesc_Arcane"
						},
						{
							"Source": {
								"Text": "Arcane Amplification"
							},
							"Translation": {
								"Text": "Arcane-amplifikáció"
							},
							"Key": "PassiveName_Arcane"
						},
						{
							"Source": {
								"Text": "Calls down 5 meteor strikes at random positions around the hero, dealing heavy AOE damage after a short delay."
							},
							"Translation": {
								"Text": "5 meteor csapást mér a hős körül, súlyos AOE károkat okoz egy rövid késés után."
							},
							"Key": "UltDesc_MeteorStrike"
						},
						{
							"Source": {
								"Text": "Chain Lightning"
							},
							"Translation": {
								"Text": "Láncvillám"
							},
							"Key": "UltName_ChainLightning"
						},
						{
							"Source": {
								"Text": "Consecutive attacks on the same target deal +8% damage per hit (max 5 stacks, +40%). Switching targets resets stacks."
							},
							"Translation": {
								"Text": "Egyazon cél elleni közvetett támadások + 8% kár / találat (max. 5 köteg, + 40%). A célpontok visszaállítása."
							},
							"Key": "PassiveDesc_Marksman"
						},
						{
							"Source": {
								"Text": "Deals flat damage to all enemies on the field. 30-second cooldown."
							},
							"Translation": {
								"Text": "A mezőn lévő összes ellenséget laposra verte. 30 másodperc hűtés."
							},
							"Key": "UltDesc_None"
						},
						{
							"Source": {
								"Text": "Each enemy kill grants a stack of +15% attack speed (max 3 stacks). Stacks expire after 3 seconds without a kill."
							},
							"Translation": {
								"Text": "Minden ellenség megöl ad egy halom + 15% támadási sebesség (max 3 stack). A stacks 3 másodperc után öl."
							},
							"Key": "PassiveDesc_Rally"
						},
						{
							"Source": {
								"Text": "Enemies suffering from a DOT effect take 15% bonus damage from all your attacks."
							},
							"Translation": {
								"Text": "Az ellenségek, akik DOT-hatástól szenvednek, 15% -os bónusz kárt szenvednek a támadásaiktól."
							},
							"Key": "PassiveDesc_Toxin"
						},
						{
							"Source": {
								"Text": "Enter a two-minute sniper stance. Right click toggles the scope, mouse wheel adjusts zoom, and left click fires piercing shots that execute normal enemies and chunk bosses for 5% of max HP."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltDesc_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Fires 10 piercing rays outward from the hero. Each ray damages all enemies in its path."
							},
							"Translation": {
								"Text": "Tüzel 10 piercing sugarak kifelé a hős. Minden sugár kárt tesz az útjában álló ellenségekben."
							},
							"Key": "UltDesc_SpearStorm"
						},
						{
							"Source": {
								"Text": "Iron Will"
							},
							"Translation": {
								"Text": "VasWill"
							},
							"Key": "PassiveName_IronWill"
						},
						{
							"Source": {
								"Text": "Lightning chains to every enemy in range with no falloff, dealing full damage to each target."
							},
							"Translation": {
								"Text": "Lightning láncok minden ellenség hatótávolságon belül, anélkül, hogy lepattanna, foglalkozik a teljes kár minden célpont."
							},
							"Key": "UltDesc_ChainLightning"
						},
						{
							"Source": {
								"Text": "Marksman's Focus"
							},
							"Translation": {
								"Text": "Marksman Focus"
							},
							"Key": "PassiveName_Marksman"
						},
						{
							"Source": {
								"Text": "Meteor Strike"
							},
							"Translation": {
								"Text": "Meteor sztrájk"
							},
							"Key": "UltName_MeteorStrike"
						},
						{
							"Source": {
								"Text": "No Passive"
							},
							"Translation": {
								"Text": "Passzív"
							},
							"Key": "PassiveName_None"
						},
						{
							"Source": {
								"Text": "Plague Cloud"
							},
							"Translation": {
								"Text": "Járványfelhő"
							},
							"Key": "UltName_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Rallying Blow"
							},
							"Translation": {
								"Text": "Rallying Flow"
							},
							"Key": "PassiveName_Rally"
						},
						{
							"Source": {
								"Text": "Reduces all incoming damage by twice your Armor stat (minimum 1 damage taken)."
							},
							"Translation": {
								"Text": "Csökkenti az összes bejövő kárt kétszer a Armor state (minimum 1 kár vett)."
							},
							"Key": "PassiveDesc_IronWill"
						},
						{
							"Source": {
								"Text": "Scoped Sniper"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltName_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Smite"
							},
							"Translation": {
								"Text": "Szippantás"
							},
							"Key": "UltName_None"
						},
						{
							"Source": {
								"Text": "Spawns a poisonous cloud at the hero's location that deals damage over time to all enemies inside it."
							},
							"Translation": {
								"Text": "Mérgező felhőt gyárt a hős tartózkodási helyén, ami idővel kárt okoz az ellenségeinek."
							},
							"Key": "UltDesc_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Spear Storm"
							},
							"Translation": {
								"Text": "Spear Storm"
							},
							"Key": "UltName_SpearStorm"
						},
						{
							"Source": {
								"Text": "Toxin Stacking"
							},
							"Translation": {
								"Text": "Toxin raktározás"
							},
							"Key": "PassiveName_Toxin"
						}
					]
				},
