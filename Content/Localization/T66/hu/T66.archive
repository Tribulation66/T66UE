				{
					"Namespace": "HeroQuotes",
					"Children": [
						{
							"Source": {
								"Text": "\"Bite back.\""
							},
							"Translation": {
								"Text": "\"Harapj vissza\"."
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "\"Catch me first.\""
							},
							"Translation": {
								"Text": "\"Kapj el előbb\"."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "\"Cold wins.\""
							},
							"Translation": {
								"Text": "\"A hideg győz\"."
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "\"Directive: survive.\""
							},
							"Translation": {
								"Text": "\"Irányelv: túlélés\"."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "\"Embrace the venom.\""
							},
							"Translation": {
								"Text": "\"Legyen csúnya\"."
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "\"Fast hands, faster kill.\""
							},
							"Translation": {
								"Text": "\"Gyors kezek, gyorsabb gyilkolás\"."
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "\"For honor.\""
							},
							"Translation": {
								"Text": "\"A vihar engedelmeskedik\"."
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "\"Gold outlasts gods.\""
							},
							"Translation": {
								"Text": "\"Az arany túléli az isteneket\"."
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "\"Hold the line.\""
							},
							"Translation": {
								"Text": "\"Tartsd a vonalat\"."
							},
							"Key": "Hero_1"
						},
						{
							"Source": {
								"Text": "\"It gets worse.\""
							},
							"Translation": {
								"Text": "\"Egyre rosszabb lesz\"."
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "\"Kneel to thunder.\""
							},
							"Translation": {
								"Text": "\"Térdre a mennydörgésre\"."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "\"Send it.\""
							},
							"Translation": {
								"Text": "\"Küldd el\"."
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "\"Stay sharp.\""
							},
							"Translation": {
								"Text": "\"Légy résen\"."
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "\"Strike true.\""
							},
							"Translation": {
								"Text": "\"Törj be előttem\"."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "\"Unlucky for them.\""
							},
							"Translation": {
								"Text": "\"Szerencsétlenek\"."
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "\"You won't see dawn.\""
							},
							"Translation": {
								"Text": "\"Nem fogod látni a hajnalt\"."
							},
							"Key": "Hero_11"
						}
					]
				},
				{
					"Namespace": "HeroSelection",
					"Children": [
						{
							"Source": {
								"Text": "Base Stats"
