						},
						{
							"Source": {
								"Text": "Character Vertex Snap Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexSnapLabel"
						},
						{
							"Source": {
								"Text": "Chromatic Aberration And Pixelation"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXSectionChromatic"
						},
						{
							"Source": {
								"Text": "Chromatic Aberration Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticStrengthLabel"
						},
						{
							"Source": {
								"Text": "Controls how thick the UE5RFX fog becomes once fog is enabled."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogDensityBody"
						},
						{
							"Source": {
								"Text": "Controls the radial RGB split strength for the custom chromatic-aberration post-process pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticStrengthBody"
						},
						{
							"Source": {
								"Text": "Controls the radial screen distortion strength used by the chromatic-aberration pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticDistortionBody"
						},
						{
							"Source": {
								"Text": "Controls the strength of the gameplay haze from 0 to 100. 0 disables native fog entirely, 100 is intentionally very heavy."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "NativeFogIntensityBody"
						},
						{
							"Source": {
								"Text": "Defaults restored."
							},
							"Translation": {
								"Text": "デフォルトは復元されます。"
							},
							"Key": "DefaultsRestored"
						},
						{
							"Source": {
								"Text": "Distortion Strength"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticDistortionLabel"
						},
						{
							"Source": {
								"Text": "Drives the existing T66 pixelation subsystem from 0 to full strength."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPixelationBody"
						},
						{
							"Source": {
								"Text": "Enable Media Viewer (TikTok / YouTube Shorts)"
							},
							"Translation": {
								"Text": "Media Viewerを有効にする (TikTok / YouTube Shorts)"
							},
							"Key": "MediaViewerEnable"
						},
						{
							"Source": {
								"Text": "Enables or disables the fake UV resolution switch."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResUVBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the fake screen-size resolution switch."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResSizeBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the imported UE5RFX color LUT stage. Color Boost only shows when this is enabled."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1ColorLUTBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the low-fake-resolution path used by the N64 blur pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXN64LowResBody"
						},
						{
							"Source": {
								"Text": "Enables or disables the visible PS1 fog contribution by gating its density."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogBody"
						},
						{
							"Source": {
								"Text": "Enter a value from 0 to 100."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GameplayNumericHelp"
						},
						{
							"Source": {
								"Text": "Enter a value from 0 to 100."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXNumericHint"
						},
						{
							"Source": {
								"Text": "Fake Resolution Size Switch"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResSizeLabel"
						},
						{
							"Source": {
								"Text": "Fake Resolution UV Switch"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXResUVLabel"
						},
						{
							"Source": {
								"Text": "Far-distance threshold for character affine mapping. 50 matches the imported sample default."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineD3Body"
						},
						{
							"Source": {
								"Text": "Far-distance threshold for world affine mapping. 50 matches the imported sample default."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldAffineD3Body"
						},
						{
							"Source": {
								"Text": "Flips the radial distortion direction used by the chromatic-aberration pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticInvertBody"
						},
						{
							"Source": {
								"Text": "Fog"
							},
							"Translation": {
								"Text": "フォグ"
							},
							"Key": "Fog"
						},
						{
							"Source": {
								"Text": "Fullscreen"
							},
							"Translation": {
								"Text": "フルスクリーン"
							},
							"Key": "Fullscreen"
						},
						{
							"Source": {
								"Text": "GAMEPLAY"
							},
							"Translation": {
								"Text": "ゲームプレイ"
							},
							"Key": "TabGameplay"
						},
						{
							"Source": {
								"Text": "GRAPHICS"
							},
							"Translation": {
								"Text": "グラフィック"
							},
							"Key": "TabGraphics"
						},
						{
							"Source": {
								"Text": "HUD"
							},
							"Translation": {
								"Text": "ハードウェア"
							},
							"Key": "TabHUD"
						},
						{
							"Source": {
								"Text": "Higher values drive the target height lower, which makes the scene feel more aggressively low-res."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXTargetResBody"
						},
						{
							"Source": {
								"Text": "Higher values increase the blur sample count in the N64 pass."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXN64StepsBody"
						},
						{
							"Source": {
								"Text": "Higher values lower the target snap resolution, making hero and enemy geometry wobble more aggressively."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexSnapResBody"
						},
						{
							"Source": {
								"Text": "Higher values lower the target snap resolution, making the world wobble and step more aggressively."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldVertexSnapResBody"
						},
						{
							"Source": {
								"Text": "Higher values pull the fog closer to the camera for a heavier retro atmosphere."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogStartBody"
						},
						{
							"Source": {
								"Text": "Higher values push the imported UE5RFX PS1 sample toward a stronger LUT color boost."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1ColorBoostBody"
						},
						{
							"Source": {
								"Text": "Higher values tighten the fog falloff distance for a denser wall of haze."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1FogFalloffBody"
						},
						{
							"Source": {
								"Text": "Idol slots"
							},
							"Translation": {
								"Text": "アイドルスロット"
							},
							"Key": "HudIdolSlots"
						},
						{
