					"Subnamespaces": [
						{
							"Namespace": "Fallback",
							"Children": [
								{
									"Source": {
										"Text": "1. Lower Quality to \"Best Performance\" in the Graphics tab.\n2. Disable \"Intense Visuals\" in the Gameplay tab.\n3. Reduce FPS Cap to 60 in the Graphics tab.\n4. Try Windowed mode instead of Fullscreen."
									},
									"Translation": {
										"Text": "1。 グラフィックスタブで「最高のパフォーマンス」に品質を下げます。\n2 .Gameplayタブで「インテンスビジュアル」を無効にします。\n3 . グラフィックスタブでFPSキャップを60に削減します。\n3 . フルスクリーンの代わりにウィンドウモードを試みて下さい。"
									},
									"Key": "CrashingChecklistBody"
								},
								{
									"Source": {
										"Text": "APPLY"
									},
									"Translation": {
										"Text": "アプリケーション"
									},
									"Key": "APPLY"
								},
								{
									"Source": {
										"Text": "Apply Safe Mode Settings"
									},
									"Translation": {
										"Text": "安全なモード設定を適用"
									},
									"Key": "Apply Safe Mode Settings"
								},
								{
									"Source": {
										"Text": "Attack Lock"
									},
									"Translation": {
