							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXChromaticInvertLabel"
						},
						{
							"Source": {
								"Text": "Mid-distance threshold for character affine mapping. 50 matches the imported sample default."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterAffineD2Body"
						},
						{
							"Source": {
								"Text": "Mid-distance threshold for world affine mapping. 50 matches the imported sample default."
