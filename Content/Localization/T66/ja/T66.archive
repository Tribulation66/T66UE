					"Children": [
						{
							"Source": {
								"Text": "COMPANION GRID"
							},
							"Translation": {
								"Text": "コンパニオングリッド"
							},
							"Key": "Title"
						},
						{
							"Source": {
								"Text": "NO COMPANION"
							},
							"Translation": {
								"Text": "参加なし"
							},
							"Key": "NoCompanion"
						}
					]
				},
				{
					"Namespace": "CompanionLore",
					"Children": [
						{
							"Source": {
								"Text": "A cunning trickster with a heart of gold."
							},
							"Translation": {
								"Text": "ゴールドの心と輝くトリックスター。"
							},
							"Key": "Companion_05"
						},
						{
							"Source": {
								"Text": "A mysterious companion."
							},
							"Translation": {
								"Text": "神秘的な仲間。"
							},
							"Key": "Unknown"
						},
						{
							"Source": {
								"Text": "A steadfast guardian who never leaves your side."
							},
							"Translation": {
								"Text": "あなたの側を離れることのない着実な保護者。"
							},
							"Key": "Companion_01"
						},
						{
							"Source": {
								"Text": "Born in flames, she heals through sheer willpower."
							},
							"Translation": {
								"Text": "炎で生まれた彼女は、剪断力で癒します。"
							},
							"Key": "Companion_02"
						},
						{
							"Source": {
								"Text": "Draws strength from moonlight to shield allies."
							},
							"Translation": {
								"Text": "月光から盾する味方への爪の強さ。"
							},
							"Key": "Companion_06"
						},
						{
							"Source": {
								"Text": "Forged in the depths, tempered by tribulation."
							},
							"Translation": {
								"Text": "深さで鍛造, 部族によって強化."
							},
							"Key": "Companion_07"
						},
						{
							"Source": {
								"Text": "Loner Style"
							},
							"Translation": {
								"Text": "ローナースタイル"
							},
							"Key": "NoCompanion"
						},
						{
							"Source": {
								"Text": "No lore available."
							},
							"Translation": {
								"Text": "貸し出しはございません。"
							},
							"Key": "FallbackLore"
						},
						{
							"Source": {
								"Text": "Once a wanderer, now sworn to protect the fallen."
							},
							"Translation": {
								"Text": "ワンダラーが倒れたら、倒れを防止します。"
							},
							"Key": "Companion_03"
						},
						{
							"Source": {
								"Text": "The last of her kind, fighting to survive."
							},
							"Translation": {
								"Text": "生き生き残るために戦う彼女の種の最後の。"
							},
							"Key": "Companion_08"
						},
						{
							"Source": {
								"Text": "Whispers ancient prayers that mend broken bones."
							},
							"Translation": {
								"Text": "壊れた骨を飾った古代の祈りを誇っています。"
							},
							"Key": "Companion_04"
						}
					]
				},
