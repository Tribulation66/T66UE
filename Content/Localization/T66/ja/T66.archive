									},
									"Translation": {
										"Text": "最高の品質"
									},
									"Key": "Best Quality"
								},
								{
									"Source": {
										"Text": "CLEAR"
									},
									"Translation": {
										"Text": "リクルート"
									},
									"Key": "CLEAR"
								},
								{
