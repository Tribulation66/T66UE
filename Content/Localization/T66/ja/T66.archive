				{
					"Namespace": "Settings",
					"Children": [
						{
							"Source": {
								"Text": "0 disables dithering. Higher values push more of the imported UE5RFX PS1 dither pattern."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXPs1DitherBody"
						},
						{
							"Source": {
