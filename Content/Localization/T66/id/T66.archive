					"Children": [
						{
							"Source": {
								"Text": "Items have primary stat lines but might have more."
							},
							"Translation": {
								"Text": "Item memiliki status primer baris tetapi mungkin memiliki lebih."
							},
							"Key": "Step_ItemsExplain"
						},
						{
							"Source": {
								"Text": "Space bar for jump"
							},
							"Translation": {
								"Text": "Space bar untuk melompat"
							},
							"Key": "Step_Jump"
						},
						{
							"Source": {
								"Text": "That bag has an item press f to pick it up"
