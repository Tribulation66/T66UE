				{
					"Namespace": "HeroDescriptions",
					"Children": [
						{
							"Source": {
								"Text": "A chaos-fueled duelist who wins fights by overwhelming the room."
							},
							"Translation": {
								"Text": "A chaos-didorong duelist yang menang perkelahian dengan luar biasa ruangan."
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "A cold-eyed wanderer hardened by long roads and worse winters."
							},
							"Translation": {
								"Text": "Seorang pengembara bermata dingin mengeras oleh jalan panjang dan musim dingin yang lebih buruk."
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "A deadpan menace who walks into disaster without blinking."
							},
							"Translation": {
								"Text": "Sebuah ancaman deadpan yang berjalan ke bencana tanpa berkedip."
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "A disciplined duelist with a steady hand and colder nerve."
							},
							"Translation": {
								"Text": "Sebuah duelist disiplin dengan tangan yang stabil dan saraf dingin."
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "A grim scavenger king draped in dust, gold, and bad omens."
							},
							"Translation": {
								"Text": "Seorang raja pemulung suram terbungkus dalam debu, emas, dan pertanda buruk."
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "A loyal brawler who charges first and doubts later."
							},
							"Translation": {
								"Text": "Seorang brawler setia yang biaya pertama dan keraguan kemudian."
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "A nimble trickster who never stays where danger lands."
							},
							"Translation": {
								"Text": "Seorang penipu gesit yang tidak pernah tinggal di tempat bahaya tanah."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "A quick-draw outlaw who turns panic into momentum."
							},
							"Translation": {
								"Text": "Sebuah penjahat cepat menarik yang berubah panik menjadi momentum."
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "A relentless machine built to keep marching through the swarm."
							},
							"Translation": {
								"Text": "Sebuah mesin tanpa henti dibangun untuk terus berbaris melalui kawanan."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "A silent hunter who lets the dark speak for him."
							},
							"Translation": {
								"Text": "Seorang pemburu diam yang membiarkan kegelapan berbicara untuknya."
							},
							"Key": "Hero_11"
						},
						{
							"Source": {
								"Text": "A storm-crowned tyrant who fights like thunder made flesh."
							},
							"Translation": {
								"Text": "Seorang penganiaya dinobatkan yang bertarung seperti guntur."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "A stubborn survivor who drags every doomed run across the line."
							},
							"Translation": {
								"Text": "Seorang yang selamat yang keras kepala yang menyeret setiap ditakdirkan berjalan melintasi garis."
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "DOT and evasion. Poison and strike."
							},
							"Translation": {
								"Text": "Sebuah bruiser jalanan yang tumbuh subur ketika pertarungan berubah berantakan."
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "Fast bouncer. Chains to multiple foes."
							},
							"Translation": {
								"Text": "Seorang panglima perang yang melanggar garis musuh melalui kekuatan belaka."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "Select a hero to view their description."
							},
							"Translation": {
								"Text": "Pilih pahlawan untuk melihat deskripsi mereka."
							},
							"Key": "SelectHeroPrompt"
						},
						{
							"Source": {
								"Text": "Steadfast knight. Ready for battle."
							},
							"Translation": {
								"Text": "Seorang penyihir tua yang tenang menyembunyikan kekuatan mengerikan."
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "Sturdy frontline. Favors armor."
							},
							"Translation": {
								"Text": "Garis depan yang licin. Baju besi favorit."
							},
							"Key": "Hero_1"
						}
					]
				},
