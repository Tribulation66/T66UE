{
	"FormatVersion": 2,
	"Namespace": "",
	"Subnamespaces": [
		{
			"Namespace": "T66",
			"Subnamespaces": [
				{
					"Namespace": "Abilities",
					"Children": [
						{
							"Source": {
								"Text": "AOE attacks that hit 3+ enemies deal 20% bonus damage. Hitting 5+ enemies increases the bonus to 35%."
							},
							"Translation": {
								"Text": "Serangan AOE yang menyerang 3 + musuh menangani kerusakan bonus 20%. Memukul 5 + musuh meningkatkan bonus menjadi 35%."
							},
							"Key": "PassiveDesc_Arcane"
						},
						{
							"Source": {
								"Text": "Arcane Amplification"
							},
							"Translation": {
								"Text": "Amplifikasi misterius"
							},
							"Key": "PassiveName_Arcane"
						},
						{
							"Source": {
								"Text": "Calls down 5 meteor strikes at random positions around the hero, dealing heavy AOE damage after a short delay."
							},
							"Translation": {
								"Text": "Panggilan turun 5 meteor pemogokan pada posisi acak sekitar pahlawan, berurusan kerusakan AOE berat setelah penundaan singkat."
							},
							"Key": "UltDesc_MeteorStrike"
						},
						{
							"Source": {
								"Text": "Chain Lightning"
							},
							"Translation": {
								"Text": "Petir Rantai"
							},
							"Key": "UltName_ChainLightning"
						},
						{
							"Source": {
								"Text": "Consecutive attacks on the same target deal +8% damage per hit (max 5 stacks, +40%). Switching targets resets stacks."
							},
							"Translation": {
								"Text": "Serangan balasan pada kesepakatan target yang sama + 8% kerusakan per pukulan (max 5 tumpukan, + 40%). Mengubah target mengatur ulang tumpukan."
							},
							"Key": "PassiveDesc_Marksman"
						},
						{
							"Source": {
								"Text": "Deals flat damage to all enemies on the field. 30-second cooldown."
							},
							"Translation": {
								"Text": "Deals kerusakan datar untuk semua musuh di lapangan. 30 detik tenang."
							},
							"Key": "UltDesc_None"
						},
						{
							"Source": {
								"Text": "Each enemy kill grants a stack of +15% attack speed (max 3 stacks). Stacks expire after 3 seconds without a kill."
							},
							"Translation": {
								"Text": "Setiap musuh membunuh hibah tumpukan + 15% kecepatan serangan (max 3 tumpukan). Tumpukan berakhir setelah 3 detik tanpa membunuh."
							},
							"Key": "PassiveDesc_Rally"
						},
						{
							"Source": {
								"Text": "Enemies suffering from a DOT effect take 15% bonus damage from all your attacks."
							},
							"Translation": {
								"Text": "Musuh menderita efek DOT mengambil 15% kerusakan bonus dari semua serangan Anda."
							},
							"Key": "PassiveDesc_Toxin"
						},
						{
							"Source": {
								"Text": "Enter a two-minute sniper stance. Right click toggles the scope, mouse wheel adjusts zoom, and left click fires piercing shots that execute normal enemies and chunk bosses for 5% of max HP."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltDesc_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Fires 10 piercing rays outward from the hero. Each ray damages all enemies in its path."
							},
							"Translation": {
								"Text": "Api 10 menusuk sinar luar dari pahlawan. Setiap ray merusak semua musuh di jalan."
							},
							"Key": "UltDesc_SpearStorm"
						},
						{
							"Source": {
								"Text": "Iron Will"
							},
							"Translation": {
								"Text": "Iron Will"
							},
							"Key": "PassiveName_IronWill"
						},
						{
							"Source": {
								"Text": "Lightning chains to every enemy in range with no falloff, dealing full damage to each target."
							},
							"Translation": {
								"Text": "Petir rantai untuk setiap musuh dalam jangkauan tanpa falloff, menangani kerusakan penuh untuk setiap target."
							},
							"Key": "UltDesc_ChainLightning"
						},
						{
							"Source": {
								"Text": "Marksman's Focus"
							},
							"Translation": {
								"Text": "Fokus Marksman"
							},
							"Key": "PassiveName_Marksman"
						},
						{
							"Source": {
								"Text": "Meteor Strike"
							},
							"Translation": {
								"Text": "Strike Meteor"
							},
							"Key": "UltName_MeteorStrike"
						},
						{
							"Source": {
								"Text": "No Passive"
							},
							"Translation": {
								"Text": "Tidak Passive"
							},
							"Key": "PassiveName_None"
						},
						{
							"Source": {
								"Text": "Plague Cloud"
							},
							"Translation": {
								"Text": "Awan Wabah"
							},
							"Key": "UltName_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Rallying Blow"
							},
							"Translation": {
								"Text": "Tiup Berderap"
							},
							"Key": "PassiveName_Rally"
						},
						{
							"Source": {
								"Text": "Reduces all incoming damage by twice your Armor stat (minimum 1 damage taken)."
							},
							"Translation": {
								"Text": "Reduces semua kerusakan masuk dua kali Anda Armor stat (minimum 1 kerusakan diambil)."
							},
							"Key": "PassiveDesc_IronWill"
						},
						{
							"Source": {
								"Text": "Scoped Sniper"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltName_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Smite"
							},
							"Translation": {
								"Text": "Smite"
							},
							"Key": "UltName_None"
						},
						{
							"Source": {
								"Text": "Spawns a poisonous cloud at the hero's location that deals damage over time to all enemies inside it."
							},
							"Translation": {
								"Text": "Spawns awan beracun di lokasi pahlawan yang menangani kerusakan dari waktu ke semua musuh di dalamnya."
							},
							"Key": "UltDesc_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Spear Storm"
							},
							"Translation": {
								"Text": "Spear Storm"
							},
							"Key": "UltName_SpearStorm"
						},
						{
							"Source": {
								"Text": "Toxin Stacking"
							},
							"Translation": {
								"Text": "Stacking Toxin"
							},
							"Key": "PassiveName_Toxin"
						}
					]
				},
