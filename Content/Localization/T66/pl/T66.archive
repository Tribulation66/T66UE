				{
					"Namespace": "HeroDescriptions",
					"Children": [
						{
							"Source": {
								"Text": "A chaos-fueled duelist who wins fights by overwhelming the room."
							},
							"Translation": {
								"Text": "Duester, który wygrywa walki przytłaczając pokój."
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "A cold-eyed wanderer hardened by long roads and worse winters."
							},
							"Translation": {
								"Text": "Zimnooki wędkarz zahartowany przez długie drogi i gorsze zimy."
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "A deadpan menace who walks into disaster without blinking."
							},
							"Translation": {
								"Text": "Deadpan, który wpada w katastrofę bez mrugnięcia okiem."
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "A disciplined duelist with a steady hand and colder nerve."
							},
							"Translation": {
								"Text": "Zdyscyplinowany duester ze stabilną ręką i chłodniejszym nerwem."
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "A grim scavenger king draped in dust, gold, and bad omens."
							},
							"Translation": {
								"Text": "Potężny król padlinożerca w kurzu, złocie i złych omenach."
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "A loyal brawler who charges first and doubts later."
							},
							"Translation": {
								"Text": "Lojalny awanturnik, który najpierw bierze zarzuty, a później wątpi."
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "A nimble trickster who never stays where danger lands."
							},
							"Translation": {
								"Text": "Zwinny oszust, który nigdy nie zostaje tam, gdzie wyląduje niebezpieczeństwo."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "A quick-draw outlaw who turns panic into momentum."
							},
							"Translation": {
								"Text": "Szybki banita, który zmienia panikę w pęd."
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "A relentless machine built to keep marching through the swarm."
							},
							"Translation": {
								"Text": "Bezlitosna maszyna zbudowana, by maszerować przez rój."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "A silent hunter who lets the dark speak for him."
							},
							"Translation": {
								"Text": "Cichy myśliwy, który pozwala mrocznym mówić za niego."
							},
							"Key": "Hero_11"
						},
						{
							"Source": {
								"Text": "A storm-crowned tyrant who fights like thunder made flesh."
							},
							"Translation": {
								"Text": "Burzowo koronowany tyran, który walczy jak piorun."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "A stubborn survivor who drags every doomed run across the line."
							},
							"Translation": {
								"Text": "Uparty ocalały, który ciągnie za sobą wszystkich skazańców."
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "DOT and evasion. Poison and strike."
							},
							"Translation": {
								"Text": "Bruiser, który rozkwita, gdy walka zamienia się w bałagan."
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "Fast bouncer. Chains to multiple foes."
							},
							"Translation": {
								"Text": "Wojownik, który przełamuje linie wroga przez czystą siłę."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "Select a hero to view their description."
							},
							"Translation": {
								"Text": "Wybierz bohatera, aby zobaczyć ich opis."
							},
							"Key": "SelectHeroPrompt"
						},
						{
							"Source": {
								"Text": "Steadfast knight. Ready for battle."
							},
							"Translation": {
								"Text": "Stary czarownik, którego spokój ukrywa przerażającą moc."
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "Sturdy frontline. Favors armor."
							},
							"Translation": {
								"Text": "Ostra linia frontu. Ulubiona zbroja."
							},
							"Key": "Hero_1"
						}
					]
				},
