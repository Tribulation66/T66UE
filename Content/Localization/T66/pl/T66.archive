				{
					"Namespace": "StatTooltips",
					"Children": [
						{
							"Source": {
								"Text": "A unique casino token that improves item sell prices. Higher levels push the sell rate up to 100%."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GamblerToken"
						},
						{
							"Source": {
								"Text": "Aggro generation multiplier. Higher values draw more enemy attention."
							},
							"Translation": {
								"Text": "Mnożnik generacji Aggro. Wyższe wartości przyciągają więcej uwagi wroga."
							},
							"Key": "Taunt"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Atak premia prędkości dla area-of-efekt ataków."
							},
							"Key": "AoeSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Premia za prędkość ataku do odbijania ataków pocisków."
							},
							"Key": "BounceSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Atak premia prędkości dla skutków demage- nadmiar czasu."
							},
							"Key": "DotSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Premia za prędkość ataku."
							},
							"Key": "PierceSpeed"
						},
						{
							"Source": {
								"Text": "Base damage dealt by each attack. Increased by items and level-ups."
							},
							"Translation": {
								"Text": "Uszkodzenia bazowe spowodowane każdym atakiem. Zwiększone o przedmioty i poziomy."
							},
							"Key": "Damage"
						},
						{
							"Source": {
								"Text": "Bonus damage for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Uszkodzenia premiowe w przypadku ataków o zasięgu przestrzennym."
							},
							"Key": "AoeDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Uszkodzenia premiowe za odbijanie pocisków."
							},
							"Key": "BounceDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for damage-over-time effects."
							},
							"Translation": {
								"Text": "Uszkodzenia premiowe dla skutków demage- ponadczasowych."
							},
							"Key": "DotDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for piercing attacks that pass through enemies."
							},
							"Translation": {
								"Text": "Premia za ataki przebijające, które przechodzą przez wrogów."
							},
							"Key": "PierceDamage"
						},
						{
							"Source": {
								"Text": "Bonus movement speed multiplier from secondary stat sources."
							},
							"Translation": {
								"Text": "Mnożnik prędkości ruchu bonusowego z wtórnych źródeł statu."
							},
							"Key": "MovementSpeed"
						},
						{
							"Source": {
								"Text": "Chance for each attack to land a critical hit."
							},
							"Translation": {
								"Text": "Szansa na każdy atak, by uderzyć krytycznie."
							},
							"Key": "CritChance"
						},
						{
							"Source": {
								"Text": "Chance to completely dodge an incoming attack. Also unlocks evasion-based secondary stats."
							},
							"Translation": {
								"Text": "Szansa na całkowite uniknięcie ataku. Odblokowuje również wtórne statystyki oparte na evasionce."
							},
							"Key": "Evasion"
						},
						{
							"Source": {
								"Text": "Chance to confuse enemies on hit, making them lose track of you."
							},
							"Translation": {
								"Text": "Szansa na pomylenie wrogów z atakiem, sprawienie, że stracą cię."
							},
							"Key": "Invisibility"
						},
						{
							"Source": {
								"Text": "Chance to counter-attack when dodging an enemy's attack."
							},
							"Translation": {
								"Text": "Szansa na przeciwdziałanie atakom wroga."
							},
							"Key": "CounterAttack"
						},
						{
							"Source": {
								"Text": "Chance to encounter a gold-dropping goblin."
							},
							"Translation": {
								"Text": "Szansa na spotkanie złotego goblina."
							},
							"Key": "Goblin"
						},
						{
							"Source": {
								"Text": "Chance to encounter a leprechaun with bonus rewards."
							},
							"Translation": {
								"Text": "Szansa na spotkanie karła z bonusem."
							},
							"Key": "Leprechaun"
						},
						{
							"Source": {
								"Text": "Chance to find a Fountain of Life that restores health."
							},
							"Translation": {
								"Text": "Szansa na znalezienie Fontanny Życia, która przywróci zdrowie."
							},
							"Key": "Fountain"
						},
						{
							"Source": {
								"Text": "Chance to find a bonus spin wheel on the map."
							},
							"Translation": {
								"Text": "Szansa na znalezienie na mapie kołowrotka."
							},
							"Key": "SpinWheel"
						},
						{
							"Source": {
								"Text": "Chance to find a treasure chest on the map."
							},
							"Translation": {
								"Text": "Szansa na znalezienie skrzyni skarbów na mapie."
							},
							"Key": "TreasureChest"
						},
						{
							"Source": {
								"Text": "Chance to heal when dealing damage to enemies."
							},
							"Translation": {
								"Text": "Szansa na uzdrowienie przy sprzedaży szkód wrogom."
							},
							"Key": "LifeSteal"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when reflecting damage."
							},
							"Translation": {
								"Text": "Szansa na natychmiastowe zabicie wroga, gdy odbije obrażenia."
							},
							"Key": "Crush"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when you dodge their attack."
							},
							"Translation": {
								"Text": "Szansa na natychmiastowe zabicie wroga, gdy unikniesz ich ataku."
							},
							"Key": "Assassinate"
						},
						{
							"Source": {
								"Text": "Chance to reflect incoming damage back at the attacker."
							},
							"Translation": {
								"Text": "Szansa na odbicie obrażeń napływających na napastnika."
							},
							"Key": "ReflectDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier applied on critical hits. 1.5 = 50% bonus damage."
							},
							"Translation": {
								"Text": "Mnożnik uszkodzeń zastosowany do krytycznych trafień. 1.5 = 50% szkody."
							},
							"Key": "CritDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at close range."
							},
							"Translation": {
								"Text": "Mnożnik uszkodzeń podczas atakowania wrogów z bliskiej odległości."
							},
							"Key": "CloseRangeDmg"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at long range."
							},
							"Translation": {
								"Text": "Mnożnik uszkodzeń podczas atakowania wrogów z dalekiego zasięgu."
							},
							"Key": "LongRangeDmg"
						},
						{
							"Source": {
								"Text": "Health points regenerated per second."
							},
							"Translation": {
								"Text": "Punkty zdrowia regenerowane na sekundę."
							},
							"Key": "HpRegen"
						},
						{
							"Source": {
								"Text": "Hero movement speed multiplier. Higher values let you move faster across the map."
							},
							"Translation": {
								"Text": "Mnożnik prędkości ruchu bohatera. Wyższe wartości pozwalają poruszać się szybciej po mapie."
							},
							"Key": "Speed"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Premia Hitbox rozmiar dla area-of-efekt ataków."
							},
							"Key": "AoeScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Bonus Hitboxa za odbijanie ataków pocisków."
							},
							"Key": "BounceScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Premia Hitbox rozmiar dla skutków demage- nadmiar czasu."
							},
							"Key": "DotScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Premia Hitboxa za przekłuwanie."
							},
							"Key": "PierceScale"
						},
						{
							"Source": {
								"Text": "How quickly your hero attacks. Higher values reduce the interval between attacks."
							},
							"Translation": {
								"Text": "Jak szybko twój bohater atakuje. Wyższe wartości zmniejszają odstęp między atakami."
							},
							"Key": "AttackSpeed"
						},
						{
							"Source": {
								"Text": "Improves chances for rare item drops, spin-wheel bonuses, and world event spawns."
							},
							"Translation": {
								"Text": "Poprawia szanse na rzadkie spadki przedmiotów, bonusy spin- koła, i tarło światowej imprezy."
							},
							"Key": "Luck"
						},
						{
							"Source": {
								"Text": "Improves the odds of higher-rarity rewards when opening a crate."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "LootCrate"
						},
						{
							"Source": {
								"Text": "Maximum distance your attacks can reach."
							},
							"Translation": {
								"Text": "Maksymalna odległość, do której mogą dotrzeć ataki."
							},
							"Key": "AttackRange"
						},
						{
							"Source": {
								"Text": "Reduces incoming damage from all sources. Each point subtracts flat damage before HP loss."
							},
							"Translation": {
								"Text": "Zmniejsza nadchodzące uszkodzenia ze wszystkich źródeł. Każdy punkt odejmuje uszkodzenia płaskie przed utratą HP."
							},
							"Key": "Armor"
						},
						{
							"Source": {
								"Text": "Size multiplier for your attack hitbox. Larger scale hits more enemies per swing."
							},
							"Translation": {
								"Text": "Rozmiar mnożnik dla Twojego hitbox ataku. Większa skala trafia więcej wrogów na huśtawkę."
							},
							"Key": "AttackScale"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to cheat at the Gambler."
							},
							"Translation": {
								"Text": "Sukces, gdy próbujesz oszukiwać w Gambler."
							},
							"Key": "Cheating"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to steal from the Vendor."
							},
							"Translation": {
								"Text": "Sukces szansy, gdy próbujesz okraść Vendor."
							},
							"Key": "Stealing"
						},
						{
							"Source": {
								"Text": "Your hero's current level. Gain XP by killing enemies to level up and improve your stats."
							},
							"Translation": {
								"Text": "Twój bohater jest na obecnym poziomie. Zysk XP zabijając wrogów do poziomu i poprawić swoje statystyki."
							},
							"Key": "Level"
						}
					]
				},
