{
	"FormatVersion": 2,
	"Namespace": "",
	"Subnamespaces": [
		{
			"Namespace": "T66",
			"Subnamespaces": [
				{
					"Namespace": "Abilities",
					"Children": [
						{
							"Source": {
								"Text": "AOE attacks that hit 3+ enemies deal 20% bonus damage. Hitting 5+ enemies increases the bonus to 35%."
							},
							"Translation": {
								"Text": "AOE-Angriffe, die 3+ Feinde treffen, um 20% Bonus Schaden. Das Erreichen von 5+ Feinden erhöht den Bonus auf 35%."
							},
							"Key": "PassiveDesc_Arcane"
						},
						{
							"Source": {
								"Text": "Arcane Amplification"
							},
							"Translation": {
								"Text": "Arcane Verstärkung"
							},
							"Key": "PassiveName_Arcane"
						},
						{
							"Source": {
								"Text": "Calls down 5 meteor strikes at random positions around the hero, dealing heavy AOE damage after a short delay."
							},
							"Translation": {
								"Text": "Ruft 5 Meteor schlägt an zufälligen Positionen um den Helden, schwere AOE Schaden nach kurzer Verzögerung."
							},
							"Key": "UltDesc_MeteorStrike"
						},
						{
							"Source": {
								"Text": "Chain Lightning"
							},
							"Translation": {
								"Text": "Kettenbeleuchtung"
							},
							"Key": "UltName_ChainLightning"
						},
						{
							"Source": {
								"Text": "Consecutive attacks on the same target deal +8% damage per hit (max 5 stacks, +40%). Switching targets resets stacks."
							},
							"Translation": {
								"Text": "Konsequenzielle Angriffe auf den gleichen Ziel Deal +8% Schaden pro Treffer (max 5 Stacks, +40%). Die Switching-Ziele setzen Stapel zurück."
							},
							"Key": "PassiveDesc_Marksman"
						},
						{
							"Source": {
								"Text": "Deals flat damage to all enemies on the field. 30-second cooldown."
							},
							"Translation": {
								"Text": "Dealt flache Schäden an allen Feinden auf dem Feld. 30 Sekunden abkühlen."
							},
							"Key": "UltDesc_None"
						},
						{
							"Source": {
								"Text": "Each enemy kill grants a stack of +15% attack speed (max 3 stacks). Stacks expire after 3 seconds without a kill."
							},
							"Translation": {
								"Text": "Jeder Feind tötet einen Stapel von +15% Angriffsgeschwindigkeit (max 3 Stapel). Stacks verfallen nach 3 Sekunden ohne Kill."
							},
							"Key": "PassiveDesc_Rally"
						},
						{
							"Source": {
								"Text": "Enemies suffering from a DOT effect take 15% bonus damage from all your attacks."
							},
							"Translation": {
								"Text": "Feinde, die an einem DOT-Effekt leiden, nehmen 15% Bonusschaden von all Ihren Angriffen."
							},
							"Key": "PassiveDesc_Toxin"
						},
						{
							"Source": {
								"Text": "Enter a two-minute sniper stance. Right click toggles the scope, mouse wheel adjusts zoom, and left click fires piercing shots that execute normal enemies and chunk bosses for 5% of max HP."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltDesc_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Fires 10 piercing rays outward from the hero. Each ray damages all enemies in its path."
							},
							"Translation": {
								"Text": "Feuert 10 durchdringende Strahlen aus dem Helden. Jeder Strahl schädigt alle Feinde auf seinem Weg."
							},
							"Key": "UltDesc_SpearStorm"
						},
						{
							"Source": {
								"Text": "Iron Will"
							},
							"Translation": {
								"Text": "Eisen Wille"
							},
							"Key": "PassiveName_IronWill"
						},
						{
							"Source": {
								"Text": "Lightning chains to every enemy in range with no falloff, dealing full damage to each target."
							},
							"Translation": {
								"Text": "Blitzketten zu jedem Feind in Reichweite ohne Absturz, um volle Schäden an jedem Ziel."
							},
							"Key": "UltDesc_ChainLightning"
						},
						{
							"Source": {
								"Text": "Marksman's Focus"
							},
							"Translation": {
								"Text": "Marksman's Focus"
							},
							"Key": "PassiveName_Marksman"
						},
						{
							"Source": {
								"Text": "Meteor Strike"
							},
							"Translation": {
								"Text": "Meteor Strike"
							},
							"Key": "UltName_MeteorStrike"
						},
						{
							"Source": {
								"Text": "No Passive"
							},
							"Translation": {
								"Text": "Kein Passiv"
							},
							"Key": "PassiveName_None"
						},
						{
							"Source": {
								"Text": "Plague Cloud"
							},
							"Translation": {
								"Text": "Die Welt"
							},
							"Key": "UltName_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Rallying Blow"
							},
							"Translation": {
								"Text": "Rallye Blow"
							},
							"Key": "PassiveName_Rally"
						},
						{
							"Source": {
								"Text": "Reduces all incoming damage by twice your Armor stat (minimum 1 damage taken)."
							},
							"Translation": {
								"Text": "Reduziert alle ankommenden Schäden durch zweimal Ihren Armor stat (mindestens 1 Schaden genommen)."
							},
							"Key": "PassiveDesc_IronWill"
						},
						{
							"Source": {
								"Text": "Scoped Sniper"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltName_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Smite"
							},
							"Translation": {
								"Text": "Smit"
							},
							"Key": "UltName_None"
						},
						{
							"Source": {
								"Text": "Spawns a poisonous cloud at the hero's location that deals damage over time to all enemies inside it."
							},
							"Translation": {
								"Text": "Spawnt eine giftige Wolke an der Stelle des Helden, die Schaden im Laufe der Zeit an alle Feinde in ihm."
							},
							"Key": "UltDesc_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Spear Storm"
							},
							"Translation": {
								"Text": "Spear Storm"
							},
							"Key": "UltName_SpearStorm"
						},
						{
							"Source": {
								"Text": "Toxin Stacking"
							},
							"Translation": {
								"Text": "Toxin Stacking"
							},
							"Key": "PassiveName_Toxin"
						}
					]
				},
