				{
					"Namespace": "CompanionLore",
					"Children": [
						{
							"Source": {
								"Text": "A cunning trickster with a heart of gold."
							},
							"Translation": {
								"Text": "Ein gerissener Trickster mit einem Herzen von Gold."
							},
							"Key": "Companion_05"
						},
						{
							"Source": {
								"Text": "A mysterious companion."
							},
							"Translation": {
								"Text": "Ein geheimnisvoller Begleiter."
							},
							"Key": "Unknown"
						},
						{
							"Source": {
								"Text": "A steadfast guardian who never leaves your side."
							},
							"Translation": {
								"Text": "Ein fester Wächter, der nie deine Seite verlässt."
							},
							"Key": "Companion_01"
						},
						{
							"Source": {
								"Text": "Born in flames, she heals through sheer willpower."
							},
							"Translation": {
								"Text": "In Flammen geboren, heilt sie durch schiere Willenskraft."
							},
							"Key": "Companion_02"
						},
						{
							"Source": {
								"Text": "Draws strength from moonlight to shield allies."
							},
							"Translation": {
								"Text": "Zeichnet Stärke von Mondlicht, um Verbündete abzuschirmen."
							},
							"Key": "Companion_06"
						},
						{
							"Source": {
								"Text": "Forged in the depths, tempered by tribulation."
							},
							"Translation": {
								"Text": "Geschmiedet in den Tiefen, getempert durch Trübsal."
							},
							"Key": "Companion_07"
						},
						{
							"Source": {
								"Text": "Loner Style"
							},
							"Translation": {
								"Text": "Ich bin nicht da."
							},
							"Key": "NoCompanion"
						},
						{
							"Source": {
								"Text": "No lore available."
							},
							"Translation": {
								"Text": "Keine Spur verfügbar."
							},
							"Key": "FallbackLore"
						},
						{
							"Source": {
								"Text": "Once a wanderer, now sworn to protect the fallen."
							},
							"Translation": {
								"Text": "Einmal ein Wanderer, jetzt geschworen, um die gefallenen zu schützen."
							},
							"Key": "Companion_03"
						},
						{
							"Source": {
								"Text": "The last of her kind, fighting to survive."
							},
							"Translation": {
								"Text": "Die letzte ihrer Art, kämpfen um zu überleben."
							},
							"Key": "Companion_08"
						},
						{
							"Source": {
								"Text": "Whispers ancient prayers that mend broken bones."
							},
							"Translation": {
								"Text": "Whispers alte Gebete, die zerbrochene Knochen bedrohen."
							},
							"Key": "Companion_04"
						}
					]
				},
