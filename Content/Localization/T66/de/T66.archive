				{
					"Namespace": "HeroDescriptions",
					"Children": [
						{
							"Source": {
								"Text": "A chaos-fueled duelist who wins fights by overwhelming the room."
							},
							"Translation": {
								"Text": "Eine chaos-betankte Duelist, die Kämpfe gewinnt, indem sie den Raum überwältigt."
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "A cold-eyed wanderer hardened by long roads and worse winters."
							},
							"Translation": {
								"Text": "Ein kaltherziger Wanderer verhärtet durch lange Straßen und schlechtere Winter."
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "A deadpan menace who walks into disaster without blinking."
							},
							"Translation": {
								"Text": "Eine tödliche Bedrohung, die ohne Blinzeln ins Desaster geht."
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "A disciplined duelist with a steady hand and colder nerve."
							},
							"Translation": {
								"Text": "Eine disziplinierte Duelist mit einer stabilen Hand und einem kälteren Nerven."
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "A grim scavenger king draped in dust, gold, and bad omens."
							},
							"Translation": {
								"Text": "Ein grimmiger Schurkenkönig entblößte in Staub, Gold und schlechten Omen."
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "A loyal brawler who charges first and doubts later."
							},
							"Translation": {
								"Text": "Ein treuer Brawler, der zuerst läutet und später zweifelt."
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "A nimble trickster who never stays where danger lands."
							},
							"Translation": {
								"Text": "Ein nimble Trickster, der nie dort bleibt, wo Gefahren landen."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "A quick-draw outlaw who turns panic into momentum."
							},
							"Translation": {
								"Text": "Ein Schnellauszug, der Panik in Schwung verwandelt."
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "A relentless machine built to keep marching through the swarm."
							},
							"Translation": {
								"Text": "Eine unermüdliche Maschine, die gebaut wird, um durch den Schwarm zu marschieren."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "A silent hunter who lets the dark speak for him."
							},
							"Translation": {
								"Text": "Ein stiller Jäger, der die Dunkelheit für ihn sprechen lässt."
							},
							"Key": "Hero_11"
						},
						{
							"Source": {
								"Text": "A storm-crowned tyrant who fights like thunder made flesh."
							},
							"Translation": {
								"Text": "Ein stürmischer Tyrann, der wie Donner kämpft, machte Fleisch."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "A stubborn survivor who drags every doomed run across the line."
							},
							"Translation": {
								"Text": "Ein hartnäckiger Überlebender, der jede Verdammte zieht, läuft über die Linie."
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "DOT and evasion. Poison and strike."
							},
							"Translation": {
								"Text": "Ein straßenweiser Bruiser, der sich ernährt, wenn der Kampf mies wird."
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "Fast bouncer. Chains to multiple foes."
							},
							"Translation": {
								"Text": "Ein Kriegsherr, der feindliche Linien durch schiere Kraft bricht."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "Select a hero to view their description."
							},
							"Translation": {
								"Text": "Wählen Sie einen Helden, um ihre Beschreibung anzuzeigen."
							},
							"Key": "SelectHeroPrompt"
						},
						{
							"Source": {
								"Text": "Steadfast knight. Ready for battle."
							},
							"Translation": {
								"Text": "Ein alter Zauberer, dessen Ruhe erschreckende Macht verbirgt."
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "Sturdy frontline. Favors armor."
							},
							"Translation": {
								"Text": "Robuste Front. Favors Rüstung."
							},
							"Key": "Hero_1"
						}
					]
				},
