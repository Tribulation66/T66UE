				},
				{
					"Namespace": "HeroQuotes",
					"Children": [
						{
							"Source": {
								"Text": "\"Bite back.\""
							},
							"Translation": {
								"Text": "\"Deita-te de volta.\""
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "\"Catch me first.\""
							},
							"Translation": {
								"Text": "Apanha-me primeiro."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "\"Cold wins.\""
							},
							"Translation": {
								"Text": "\"O frio ganha.\""
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "\"Directive: survive.\""
							},
							"Translation": {
								"Text": "\"Directiva: sobreviver.\""
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "\"Embrace the venom.\""
							},
							"Translation": {
								"Text": "\"Vamos torná-lo feio.\""
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "\"Fast hands, faster kill.\""
							},
							"Translation": {
								"Text": "\"Mãos rápidas, morte rápida.\""
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "\"For honor.\""
							},
							"Translation": {
								"Text": "\"A tempestade obedece.\""
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "\"Gold outlasts gods.\""
							},
							"Translation": {
								"Text": "\"O ouro vence os deuses.\""
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "\"Hold the line.\""
							},
							"Translation": {
								"Text": "\"Segure a linha.\""
							},
							"Key": "Hero_1"
						},
						{
							"Source": {
								"Text": "\"It gets worse.\""
							},
							"Translation": {
								"Text": "\"E fica pior.\""
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "\"Kneel to thunder.\""
							},
							"Translation": {
								"Text": "Ajoelhe-se ao trovão."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "\"Send it.\""
							},
							"Translation": {
								"Text": "\"Enviar.\""
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "\"Stay sharp.\""
							},
							"Translation": {
								"Text": "\"Fica atento.\""
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "\"Strike true.\""
							},
							"Translation": {
								"Text": "\"Parte antes de mim.\""
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "\"Unlucky for them.\""
							},
							"Translation": {
								"Text": "\"Desafortunado para eles.\""
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "\"You won't see dawn.\""
							},
							"Translation": {
								"Text": "\"Não verás o amanhecer.\""
							},
							"Key": "Hero_11"
						}
					]
				},
