				{
					"Namespace": "StatTooltips",
					"Children": [
						{
							"Source": {
								"Text": "A unique casino token that improves item sell prices. Higher levels push the sell rate up to 100%."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GamblerToken"
						},
						{
							"Source": {
								"Text": "Aggro generation multiplier. Higher values draw more enemy attention."
							},
							"Translation": {
								"Text": "Multiplicador de geração Aggro. Valores mais altos chamam mais atenção do inimigo."
							},
							"Key": "Taunt"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Bónus de velocidade de ataque para ataques de área de efeito."
							},
							"Key": "AoeSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Bónus de velocidade de ataque para ataques de projéteis."
							},
							"Key": "BounceSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Bónus de velocidade de ataque para efeitos de dano-tempo."
							},
							"Key": "DotSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Bónus de velocidade de ataque para ataques perfurantes."
							},
							"Key": "PierceSpeed"
						},
						{
							"Source": {
								"Text": "Base damage dealt by each attack. Increased by items and level-ups."
							},
							"Translation": {
								"Text": "Danos causados por cada ataque. Aumento dos itens e dos níveis."
							},
							"Key": "Damage"
						},
						{
							"Source": {
								"Text": "Bonus damage for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Dano de bónus para ataques de área de efeito."
							},
							"Key": "AoeDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Dano de bónus para ataques de projécteis."
							},
							"Key": "BounceDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for damage-over-time effects."
							},
							"Translation": {
								"Text": "Dano bônus para efeitos de dano-sobre-tempo."
							},
							"Key": "DotDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for piercing attacks that pass through enemies."
							},
							"Translation": {
								"Text": "Dano bônus para ataques perfurantes que passam por inimigos."
							},
							"Key": "PierceDamage"
						},
						{
							"Source": {
								"Text": "Bonus movement speed multiplier from secondary stat sources."
							},
							"Translation": {
								"Text": "Multiplicador de velocidade de movimento bônus de fontes estatísticas secundárias."
							},
							"Key": "MovementSpeed"
						},
						{
							"Source": {
								"Text": "Chance for each attack to land a critical hit."
							},
							"Translation": {
								"Text": "A hipótese de cada ataque atingir um ataque crítico."
							},
							"Key": "CritChance"
						},
						{
							"Source": {
								"Text": "Chance to completely dodge an incoming attack. Also unlocks evasion-based secondary stats."
							},
							"Translation": {
								"Text": "A hipótese de evitar um ataque. Também desbloqueia estatísticas secundárias baseadas em evasão."
							},
							"Key": "Evasion"
						},
						{
							"Source": {
								"Text": "Chance to confuse enemies on hit, making them lose track of you."
							},
							"Translation": {
								"Text": "Chance de confundir inimigos no hit, fazendo-os perder o controle de você."
							},
							"Key": "Invisibility"
						},
						{
							"Source": {
								"Text": "Chance to counter-attack when dodging an enemy's attack."
							},
							"Translation": {
								"Text": "A hipótese de contra-atacar ao evitar o ataque de um inimigo."
							},
							"Key": "CounterAttack"
						},
						{
							"Source": {
								"Text": "Chance to encounter a gold-dropping goblin."
							},
							"Translation": {
								"Text": "A hipótese de encontrar um duende que cai ouro."
							},
							"Key": "Goblin"
						},
						{
							"Source": {
								"Text": "Chance to encounter a leprechaun with bonus rewards."
							},
							"Translation": {
								"Text": "Chance de encontrar um duende com recompensas bônus."
							},
							"Key": "Leprechaun"
						},
						{
							"Source": {
								"Text": "Chance to find a Fountain of Life that restores health."
							},
							"Translation": {
								"Text": "A possibilidade de encontrar uma Fonte de Vida que restaure a saúde."
							},
							"Key": "Fountain"
						},
						{
							"Source": {
								"Text": "Chance to find a bonus spin wheel on the map."
							},
							"Translation": {
								"Text": "Possibilidade de encontrar uma roda de giro bônus no mapa."
							},
							"Key": "SpinWheel"
						},
						{
							"Source": {
								"Text": "Chance to find a treasure chest on the map."
							},
							"Translation": {
								"Text": "É possível encontrar um baú de tesouro no mapa."
							},
							"Key": "TreasureChest"
						},
						{
							"Source": {
								"Text": "Chance to heal when dealing damage to enemies."
							},
							"Translation": {
								"Text": "Chance de curar ao causar danos aos inimigos."
							},
							"Key": "LifeSteal"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when reflecting damage."
							},
							"Translation": {
								"Text": "Possibilidade de matar instantaneamente um inimigo ao refletir danos."
							},
							"Key": "Crush"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when you dodge their attack."
							},
							"Translation": {
								"Text": "Possibilidade de matar instantaneamente um inimigo quando você evitar o ataque deles."
							},
							"Key": "Assassinate"
						},
						{
							"Source": {
								"Text": "Chance to reflect incoming damage back at the attacker."
							},
							"Translation": {
								"Text": "Possibilidade de reflectir danos no atacante."
							},
							"Key": "ReflectDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier applied on critical hits. 1.5 = 50% bonus damage."
							},
							"Translation": {
								"Text": "Multiplicador de danos aplicado em ataques críticos. 1.5 = 50% de dano bônus."
							},
							"Key": "CritDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at close range."
							},
							"Translation": {
								"Text": "Danos multiplicadores ao atacar inimigos de perto."
							},
							"Key": "CloseRangeDmg"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at long range."
							},
							"Translation": {
								"Text": "Multiplicador de danos ao atacar inimigos a longo alcance."
							},
							"Key": "LongRangeDmg"
						},
						{
							"Source": {
								"Text": "Health points regenerated per second."
							},
							"Translation": {
								"Text": "Pontos de saúde regenerados por segundo."
							},
							"Key": "HpRegen"
						},
						{
							"Source": {
								"Text": "Hero movement speed multiplier. Higher values let you move faster across the map."
							},
							"Translation": {
								"Text": "Multiplicador de velocidade de movimento herói. Valores mais elevados permitem que você se mova mais rápido através do mapa."
							},
							"Key": "Speed"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Bónus de tamanho Hitbox para ataques de área de efeito."
							},
							"Key": "AoeScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Bónus de tamanho Hitbox para ataques de projéteis."
							},
							"Key": "BounceScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Bónus de tamanho Hitbox para efeitos de dano-tempo."
							},
							"Key": "DotScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Bónus de tamanho Hitbox para ataques de perfuração."
							},
							"Key": "PierceScale"
						},
						{
							"Source": {
								"Text": "How quickly your hero attacks. Higher values reduce the interval between attacks."
							},
							"Translation": {
								"Text": "Quão rápido o teu herói ataca. Valores mais elevados reduzem o intervalo entre os ataques."
							},
							"Key": "AttackSpeed"
						},
						{
							"Source": {
								"Text": "Improves chances for rare item drops, spin-wheel bonuses, and world event spawns."
							},
							"Translation": {
								"Text": "Melhora as chances de quedas de itens raros, bônus de roda giratória e desovas de eventos mundiais."
							},
							"Key": "Luck"
						},
						{
							"Source": {
								"Text": "Improves the odds of higher-rarity rewards when opening a crate."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "LootCrate"
						},
						{
							"Source": {
								"Text": "Maximum distance your attacks can reach."
							},
							"Translation": {
								"Text": "Distância máxima que seus ataques podem atingir."
							},
							"Key": "AttackRange"
						},
						{
							"Source": {
								"Text": "Reduces incoming damage from all sources. Each point subtracts flat damage before HP loss."
							},
							"Translation": {
								"Text": "Reduz os danos de todas as fontes. Cada ponto subtrai dano plano antes da perda de HP."
							},
							"Key": "Armor"
						},
						{
							"Source": {
								"Text": "Size multiplier for your attack hitbox. Larger scale hits more enemies per swing."
							},
							"Translation": {
								"Text": "Multiplicador de tamanho para sua caixa de ataque. Maior escala atinge mais inimigos por balanço."
							},
							"Key": "AttackScale"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to cheat at the Gambler."
							},
							"Translation": {
								"Text": "É uma oportunidade de sucesso ao tentar enganar o Jogador."
							},
							"Key": "Cheating"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to steal from the Vendor."
							},
							"Translation": {
								"Text": "Uma oportunidade de sucesso ao tentar roubar o Fornecedor."
							},
							"Key": "Stealing"
						},
						{
							"Source": {
								"Text": "Your hero's current level. Gain XP by killing enemies to level up and improve your stats."
							},
							"Translation": {
								"Text": "O nível actual do teu herói. Ganhe XP matando inimigos para subir e melhorar suas estatísticas."
							},
							"Key": "Level"
						}
					]
				},
