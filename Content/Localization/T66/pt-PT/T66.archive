				{
					"Namespace": "HeroDescriptions",
					"Children": [
						{
							"Source": {
								"Text": "A chaos-fueled duelist who wins fights by overwhelming the room."
							},
							"Translation": {
								"Text": "Um duelista cheio de caos que ganha combates por esmagar a sala."
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "A cold-eyed wanderer hardened by long roads and worse winters."
							},
							"Translation": {
								"Text": "Um andarilho de olhos frios endurecido por longas estradas e invernos piores."
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "A deadpan menace who walks into disaster without blinking."
							},
							"Translation": {
								"Text": "Uma ameaça mortal que entra em desastre sem piscar."
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "A disciplined duelist with a steady hand and colder nerve."
							},
							"Translation": {
								"Text": "Um duelista disciplinado com uma mão firme e um nervo mais frio."
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "A grim scavenger king draped in dust, gold, and bad omens."
							},
							"Translation": {
								"Text": "Um rei carniceiro coberto de pó, ouro e maus presságios."
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "A loyal brawler who charges first and doubts later."
							},
							"Translation": {
								"Text": "Um lutador leal que acusa primeiro e duvida depois."
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "A nimble trickster who never stays where danger lands."
							},
							"Translation": {
								"Text": "Um trapaceiro ágil que nunca fica onde o perigo cai."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "A quick-draw outlaw who turns panic into momentum."
							},
							"Translation": {
								"Text": "Um bandido que transforma o pânico em impulso."
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "A relentless machine built to keep marching through the swarm."
							},
							"Translation": {
								"Text": "Uma máquina implacável construída para continuar a marchar através do enxame."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "A silent hunter who lets the dark speak for him."
							},
							"Translation": {
								"Text": "Um caçador silencioso que deixa a escuridão falar por ele."
							},
							"Key": "Hero_11"
						},
						{
							"Source": {
								"Text": "A storm-crowned tyrant who fights like thunder made flesh."
							},
							"Translation": {
								"Text": "Um tirano que luta como um trovão feito carne."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "A stubborn survivor who drags every doomed run across the line."
							},
							"Translation": {
								"Text": "Um sobrevivente teimoso que arrasta todos os condenados."
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "DOT and evasion. Poison and strike."
							},
							"Translation": {
								"Text": "Um patife de rua que prospera quando a luta fica confusa."
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "Fast bouncer. Chains to multiple foes."
							},
							"Translation": {
								"Text": "Um senhor da guerra que rompe as linhas inimigas através de pura força."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "Select a hero to view their description."
							},
							"Translation": {
								"Text": "Selecione um herói para ver sua descrição."
							},
							"Key": "SelectHeroPrompt"
						},
						{
							"Source": {
								"Text": "Steadfast knight. Ready for battle."
							},
							"Translation": {
								"Text": "Um velho feiticeiro cuja calma esconde um poder terrível."
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "Sturdy frontline. Favors armor."
							},
							"Translation": {
								"Text": "Linha de frente resistente. Favorece armadura."
							},
							"Key": "Hero_1"
						}
					]
				},
