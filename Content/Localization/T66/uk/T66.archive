{
	"FormatVersion": 2,
	"Namespace": "",
	"Subnamespaces": [
		{
			"Namespace": "T66",
			"Subnamespaces": [
				{
					"Namespace": "Abilities",
					"Children": [
						{
							"Source": {
								"Text": "AOE attacks that hit 3+ enemies deal 20% bonus damage. Hitting 5+ enemies increases the bonus to 35%."
							},
							"Translation": {
								"Text": "АОА атаки, які вдарили 3 + ворогів, мають 20% бонус. Хіт 5+ ворогів збільшує бонус до 35%."
							},
							"Key": "PassiveDesc_Arcane"
						},
						{
							"Source": {
								"Text": "Arcane Amplification"
							},
							"Translation": {
								"Text": "Ампліфікація Arcane"
							},
							"Key": "PassiveName_Arcane"
						},
						{
							"Source": {
								"Text": "Calls down 5 meteor strikes at random positions around the hero, dealing heavy AOE damage after a short delay."
							},
							"Translation": {
								"Text": "Викликає 5 метеорових ударів на випадкових позиціях навколо героя, що бореться з тяжкою пошкодженням АО."
							},
							"Key": "UltDesc_MeteorStrike"
						},
						{
							"Source": {
								"Text": "Chain Lightning"
							},
							"Translation": {
								"Text": "Ланцюжок Lightning"
							},
							"Key": "UltName_ChainLightning"
						},
						{
							"Source": {
								"Text": "Consecutive attacks on the same target deal +8% damage per hit (max 5 stacks, +40%). Switching targets resets stacks."
							},
							"Translation": {
								"Text": "Накопичувальні атаки на однакову цільову угоду +8% пошкодження за удар (max 5 стеків, +40%). Переключення цілей скидання стеків."
							},
							"Key": "PassiveDesc_Marksman"
						},
						{
							"Source": {
								"Text": "Deals flat damage to all enemies on the field. 30-second cooldown."
							},
							"Translation": {
								"Text": "Зняти плоскі пошкодження всіх ворогів на полі. 30-другий охолоджувач."
							},
							"Key": "UltDesc_None"
						},
						{
							"Source": {
								"Text": "Each enemy kill grants a stack of +15% attack speed (max 3 stacks). Stacks expire after 3 seconds without a kill."
							},
							"Translation": {
								"Text": "Кожна ворожа вбивця забезпечує стек атаки +15% (max 3 стеки). Стаки закінчуються після 3 секунд без вбивства."
							},
							"Key": "PassiveDesc_Rally"
						},
						{
							"Source": {
								"Text": "Enemies suffering from a DOT effect take 15% bonus damage from all your attacks."
							},
							"Translation": {
								"Text": "Сприяє стражданню від ефекту DOT приймають 15% бонусу з усіх ваших атак."
							},
							"Key": "PassiveDesc_Toxin"
						},
						{
							"Source": {
								"Text": "Enter a two-minute sniper stance. Right click toggles the scope, mouse wheel adjusts zoom, and left click fires piercing shots that execute normal enemies and chunk bosses for 5% of max HP."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltDesc_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Fires 10 piercing rays outward from the hero. Each ray damages all enemies in its path."
							},
							"Translation": {
								"Text": "Вогонь 10 пронизує промені від героя. Кожен промен зіпсує всіх ворогів у своєму шляху."
							},
							"Key": "UltDesc_SpearStorm"
						},
						{
							"Source": {
								"Text": "Iron Will"
							},
							"Translation": {
								"Text": "Залізна віза"
							},
							"Key": "PassiveName_IronWill"
						},
						{
							"Source": {
								"Text": "Lightning chains to every enemy in range with no falloff, dealing full damage to each target."
							},
							"Translation": {
								"Text": "Знімання ланцюгів до кожного ворога в діапазоні без падающих, повних шкоди кожній цілі."
							},
							"Key": "UltDesc_ChainLightning"
						},
						{
							"Source": {
								"Text": "Marksman's Focus"
							},
							"Translation": {
								"Text": "Марксман фокус"
							},
							"Key": "PassiveName_Marksman"
						},
						{
							"Source": {
								"Text": "Meteor Strike"
							},
							"Translation": {
								"Text": "Meteor удар"
							},
							"Key": "UltName_MeteorStrike"
						},
						{
							"Source": {
								"Text": "No Passive"
							},
							"Translation": {
								"Text": "Ні Пасивний"
							},
							"Key": "PassiveName_None"
						},
						{
							"Source": {
								"Text": "Plague Cloud"
							},
							"Translation": {
								"Text": "Хмара Хмара"
							},
							"Key": "UltName_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Rallying Blow"
							},
							"Translation": {
								"Text": "Ролінг удар"
							},
							"Key": "PassiveName_Rally"
						},
						{
							"Source": {
								"Text": "Reduces all incoming damage by twice your Armor stat (minimum 1 damage taken)."
							},
							"Translation": {
								"Text": "Знижує всі вхідні пошкодження за допомогою двічі вашого статуту бронетранспортера (мінімум 1 збиток)."
							},
							"Key": "PassiveDesc_IronWill"
						},
						{
							"Source": {
								"Text": "Scoped Sniper"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltName_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Smite"
							},
							"Translation": {
								"Text": "Сміт"
							},
							"Key": "UltName_None"
						},
						{
							"Source": {
								"Text": "Spawns a poisonous cloud at the hero's location that deals damage over time to all enemies inside it."
							},
							"Translation": {
								"Text": "Спроваджує отруйну хмару на місці героя, яка займається пошкодженням протягом часу для всіх ворогів всередині неї."
							},
							"Key": "UltDesc_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Spear Storm"
							},
							"Translation": {
								"Text": "Штормовий шторм"
							},
							"Key": "UltName_SpearStorm"
						},
						{
							"Source": {
								"Text": "Toxin Stacking"
							},
							"Translation": {
								"Text": "Токсин Стейкінг"
							},
							"Key": "PassiveName_Toxin"
						}
					]
				},
