							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXN64StepsBody"
						},
						{
							"Source": {
								"Text": "Higher values lower the target snap resolution, making hero and enemy geometry wobble more aggressively."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterVertexSnapResBody"
						},
						{
							"Source": {
