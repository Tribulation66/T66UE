						{
							"Source": {
								"Text": "The Media Viewer runs only on your computer. We do not receive or store the videos you watch or any data from TikTok or YouTube. To open it, use the key bound to \"Toggle Media Viewer\" or \"Toggle TikTok\" in the Controls tab."
							},
							"Translation": {
								"Text": "媒體檢視器只在您的電腦上執行 。 我們不接收或儲存您所看的影片, 要開啟它, 請使用「 切換媒體檢視器」 或「 切換控制分頁」 的按鍵 。"
							},
							"Key": "MediaViewerPrivacyBody"
						},
						{
							"Source": {
								"Text": "Theme:"
							},
							"Translation": {
								"Text": "主題 :"
							},
							"Key": "Theme"
						},
						{
							"Source": {
								"Text": "This panel drives the currently wired UE5RFX screen-space stack and the safe retro geometry swap path for T66's world and character unlit materials. Scalar settings use 0 to 100 sliders, while binary settings use ON and OFF toggles. PS1 sub-settings require PS1 Master Blend above 0 to show on screen."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXBodyExpanded"
						},
						{
							"Source": {
								"Text": "Turns the entire Retro FX stack on or off without changing the individual values below."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXMasterEnableBody"
						},
						{
							"Source": {
								"Text": "Turns the safe runtime retro-geometry swap on or off for character-facing materials that inherit from T66's shared unlit masters."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXCharacterGeometryEnableBody"
						},
						{
							"Source": {
								"Text": "Turns the safe runtime retro-geometry swap on or off for world and environment materials that inherit from T66's shared unlit masters."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "RetroFXWorldGeometryEnableBody"
						},
