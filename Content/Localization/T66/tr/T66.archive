{
	"FormatVersion": 2,
	"Namespace": "",
	"Subnamespaces": [
		{
			"Namespace": "T66",
			"Subnamespaces": [
				{
					"Namespace": "Abilities",
					"Children": [
						{
							"Source": {
								"Text": "AOE attacks that hit 3+ enemies deal 20% bonus damage. Hitting 5+ enemies increases the bonus to 35%."
							},
							"Translation": {
								"Text": "Doğrudan düşmanları vuran aOE saldırıları% 20 bonus hasar alır. Hitting 5 + düşmanları bonusu% 35'e yükseltiyor."
							},
							"Key": "PassiveDesc_Arcane"
						},
						{
							"Source": {
								"Text": "Arcane Amplification"
							},
							"Translation": {
								"Text": "Arcanelification"
							},
							"Key": "PassiveName_Arcane"
						},
						{
							"Source": {
								"Text": "Calls down 5 meteor strikes at random positions around the hero, dealing heavy AOE damage after a short delay."
							},
							"Translation": {
								"Text": "Kahramanın etrafında rastgele pozisyonlarda 5 meteor grevlerini çağırın, kısa bir gecikmeden sonra ağır AOE hasarı ele alalım."
							},
							"Key": "UltDesc_MeteorStrike"
						},
						{
							"Source": {
								"Text": "Chain Lightning"
							},
							"Translation": {
								"Text": "Zincir Yıldırım"
							},
							"Key": "UltName_ChainLightning"
						},
						{
							"Source": {
								"Text": "Consecutive attacks on the same target deal +8% damage per hit (max 5 stacks, +40%). Switching targets resets stacks."
							},
							"Translation": {
								"Text": "Aynı hedefe yönelik saldırılar +8% zarar isabet başına (max 5 yığın, +40%). Hedefleri geçiş noktaları sıfırlar."
							},
							"Key": "PassiveDesc_Marksman"
						},
						{
							"Source": {
								"Text": "Deals flat damage to all enemies on the field. 30-second cooldown."
							},
							"Translation": {
								"Text": "Anlaşmalar sahada tüm düşmanlara düz zarar verir. 30 saniyelik cooldown."
							},
							"Key": "UltDesc_None"
						},
						{
							"Source": {
								"Text": "Each enemy kill grants a stack of +15% attack speed (max 3 stacks). Stacks expire after 3 seconds without a kill."
							},
							"Translation": {
								"Text": "Her düşman, +15% saldırı hızının bir yığınını verir (max 3 yığın). Bir öldürme olmadan 3 saniyeden geçilir."
							},
							"Key": "PassiveDesc_Rally"
						},
						{
							"Source": {
								"Text": "Enemies suffering from a DOT effect take 15% bonus damage from all your attacks."
							},
							"Translation": {
								"Text": "Bir DOT etkisinden muzdarip olanlar tüm saldırılarınızdan% 15 bonus zarar alır."
							},
							"Key": "PassiveDesc_Toxin"
						},
						{
							"Source": {
								"Text": "Enter a two-minute sniper stance. Right click toggles the scope, mouse wheel adjusts zoom, and left click fires piercing shots that execute normal enemies and chunk bosses for 5% of max HP."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltDesc_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Fires 10 piercing rays outward from the hero. Each ray damages all enemies in its path."
							},
							"Translation": {
								"Text": "Kahramandan dışarı çıkan 10 piercing ışınları. Her ray, yolunda tüm düşmanları zarar verir."
							},
							"Key": "UltDesc_SpearStorm"
						},
						{
							"Source": {
								"Text": "Iron Will"
							},
							"Translation": {
								"Text": "Iron Will"
							},
							"Key": "PassiveName_IronWill"
						},
						{
							"Source": {
								"Text": "Lightning chains to every enemy in range with no falloff, dealing full damage to each target."
							},
							"Translation": {
								"Text": "Yıldırım zincirleri hiçbir düşüş olmadan her düşmana, her hedefe tam zarar vermek."
							},
							"Key": "UltDesc_ChainLightning"
						},
						{
							"Source": {
								"Text": "Marksman's Focus"
							},
							"Translation": {
								"Text": "Marksman'ın Focus"
							},
							"Key": "PassiveName_Marksman"
						},
						{
							"Source": {
								"Text": "Meteor Strike"
							},
							"Translation": {
								"Text": "Meteor Strike Strike"
							},
							"Key": "UltName_MeteorStrike"
						},
						{
							"Source": {
								"Text": "No Passive"
							},
							"Translation": {
								"Text": "No Passive"
							},
							"Key": "PassiveName_None"
						},
						{
							"Source": {
								"Text": "Plague Cloud"
							},
							"Translation": {
								"Text": "Plague Cloud"
							},
							"Key": "UltName_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Rallying Blow"
							},
							"Translation": {
								"Text": "Takmak"
							},
							"Key": "PassiveName_Rally"
						},
						{
							"Source": {
								"Text": "Reduces all incoming damage by twice your Armor stat (minimum 1 damage taken)."
							},
							"Translation": {
								"Text": "Zırh statünüzden iki kez gelen tüm gelen hasarları azaltır (mimum 1 hasar alındı)."
							},
							"Key": "PassiveDesc_IronWill"
						},
						{
							"Source": {
								"Text": "Scoped Sniper"
							},
							"Translation": {
								"Text": ""
							},
							"Key": "UltName_ScopedSniper"
						},
						{
							"Source": {
								"Text": "Smite"
							},
							"Translation": {
								"Text": "Smite"
							},
							"Key": "UltName_None"
						},
						{
							"Source": {
								"Text": "Spawns a poisonous cloud at the hero's location that deals damage over time to all enemies inside it."
							},
							"Translation": {
								"Text": "Kahramanın konumunda zehirli bir bulut, içinde tüm düşmanlarına zarar veren bir yer."
							},
							"Key": "UltDesc_PlagueCloud"
						},
						{
							"Source": {
								"Text": "Spear Storm"
							},
							"Translation": {
								"Text": "Spear Fırtına"
							},
							"Key": "UltName_SpearStorm"
						},
						{
							"Source": {
								"Text": "Toxin Stacking"
							},
							"Translation": {
								"Text": "Toxin Stackinging"
							},
							"Key": "PassiveName_Toxin"
						}
					]
