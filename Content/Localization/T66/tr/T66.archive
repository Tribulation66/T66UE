				{
					"Namespace": "CompanionLore",
					"Children": [
						{
							"Source": {
								"Text": "A cunning trickster with a heart of gold."
							},
							"Translation": {
								"Text": "Altın bir kalbi ile bir cunning numberster."
							},
							"Key": "Companion_05"
						},
						{
							"Source": {
								"Text": "A mysterious companion."
							},
							"Translation": {
								"Text": "Gizemli bir arkadaş."
							},
							"Key": "Unknown"
						},
						{
							"Source": {
								"Text": "A steadfast guardian who never leaves your side."
							},
							"Translation": {
								"Text": "Asla senin tarafını terk eden bir sadık koruyucu."
							},
							"Key": "Companion_01"
						},
						{
							"Source": {
								"Text": "Born in flames, she heals through sheer willpower."
							},
							"Translation": {
								"Text": "alevlerde doğdu, oer Willpower aracılığıyla iyileşir."
							},
							"Key": "Companion_02"
						},
						{
							"Source": {
								"Text": "Draws strength from moonlight to shield allies."
							},
							"Translation": {
								"Text": "Müttefikleri korumak için ay ışığından güç çeker."
							},
							"Key": "Companion_06"
						},
						{
							"Source": {
								"Text": "Forged in the depths, tempered by tribulation."
							},
							"Translation": {
								"Text": "Derinliklerde, tribulation tarafından sıtma."
							},
							"Key": "Companion_07"
						},
						{
							"Source": {
								"Text": "Loner Style"
							},
							"Translation": {
								"Text": "Loner Style"
							},
							"Key": "NoCompanion"
						},
						{
							"Source": {
								"Text": "No lore available."
							},
							"Translation": {
								"Text": "Hiçbir lore mevcut değil."
							},
							"Key": "FallbackLore"
						},
						{
							"Source": {
								"Text": "Once a wanderer, now sworn to protect the fallen."
							},
							"Translation": {
								"Text": "Bir kez, şimdi düşmüşlüğü korumak için yemin etti."
							},
							"Key": "Companion_03"
						},
						{
							"Source": {
								"Text": "The last of her kind, fighting to survive."
							},
							"Translation": {
								"Text": "Onun türünün sonuncusu, hayatta kalmak için savaşıyor."
							},
							"Key": "Companion_08"
						},
						{
							"Source": {
								"Text": "Whispers ancient prayers that mend broken bones."
							},
							"Translation": {
								"Text": "Whispers eski dualar erkekler kırık kemikleri."
							},
							"Key": "Companion_04"
						}
					]
				},
