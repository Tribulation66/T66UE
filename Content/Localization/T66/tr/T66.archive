				{
					"Namespace": "StatTooltips",
					"Children": [
						{
							"Source": {
								"Text": "A unique casino token that improves item sell prices. Higher levels push the sell rate up to 100%."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GamblerToken"
						},
						{
							"Source": {
								"Text": "Aggro generation multiplier. Higher values draw more enemy attention."
							},
							"Translation": {
								"Text": "Aggro nesil multiplier. Yüksek değerler daha fazla düşman dikkatini çekiyor."
							},
							"Key": "Taunt"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Bölge etkisi saldırıları için hızlı bonus."
							},
							"Key": "AoeSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Projek saldırılar için saldırı hızı bonusu."
							},
							"Key": "BounceSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Hasar zamanı etkileri için saldırı hızı bonus."
							},
							"Key": "DotSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Piercing saldırıları için hızlı bonus."
							},
							"Key": "PierceSpeed"
						},
						{
							"Source": {
								"Text": "Base damage dealt by each attack. Increased by items and level-ups."
							},
							"Translation": {
								"Text": "Her saldırı tarafından yapılan Base hasar. Maddeler ve seviyeler tarafından yükseltilir."
							},
							"Key": "Damage"
						},
						{
							"Source": {
								"Text": "Bonus damage for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Bölge etkiler için Bonus hasarı."
							},
							"Key": "AoeDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Projeci saldırılar için Bonus hasarı."
							},
							"Key": "BounceDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for damage-over-time effects."
							},
							"Translation": {
								"Text": "Hasar zamanı etkileri için Bonus hasarı."
							},
							"Key": "DotDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for piercing attacks that pass through enemies."
							},
							"Translation": {
								"Text": "Düşmanlar aracılığıyla geçen piercing saldırıları için Bonus hasar."
							},
							"Key": "PierceDamage"
						},
						{
							"Source": {
								"Text": "Bonus movement speed multiplier from secondary stat sources."
							},
							"Translation": {
								"Text": "Bonus hareket hızı ikincil istatistik kaynaklardan çok basit."
							},
							"Key": "MovementSpeed"
						},
						{
							"Source": {
								"Text": "Chance for each attack to land a critical hit."
							},
							"Translation": {
								"Text": "Her saldırının kritik bir vuruş olması için şans."
							},
							"Key": "CritChance"
						},
						{
							"Source": {
								"Text": "Chance to completely dodge an incoming attack. Also unlocks evasion-based secondary stats."
							},
							"Translation": {
								"Text": "Bir gelen saldırıyı tamamen tamamlamak için şans. Ayrıca, evasion tabanlı ikincil istatistikler kilidini da açın."
							},
							"Key": "Evasion"
						},
						{
							"Source": {
								"Text": "Chance to confuse enemies on hit, making them lose track of you."
							},
							"Translation": {
								"Text": "Düşmanları vurmak, onları senin izlerini kaybetmelerini sağlamak."
							},
							"Key": "Invisibility"
						},
						{
							"Source": {
								"Text": "Chance to counter-attack when dodging an enemy's attack."
							},
							"Translation": {
								"Text": "Düşmanın saldırısını yaparken karşılanma şansı."
							},
							"Key": "CounterAttack"
						},
						{
							"Source": {
								"Text": "Chance to encounter a gold-dropping goblin."
							},
							"Translation": {
								"Text": "Bir altın damlama goblin ile karşılaşma şansı."
							},
							"Key": "Goblin"
						},
						{
							"Source": {
								"Text": "Chance to encounter a leprechaun with bonus rewards."
							},
							"Translation": {
								"Text": "bonus ödülleri ile bir leprechaun ile karşılaşma şansı."
							},
							"Key": "Leprechaun"
						},
						{
							"Source": {
								"Text": "Chance to find a Fountain of Life that restores health."
							},
							"Translation": {
								"Text": "Sağlık restore eden bir Yaşam Çeşmesi bulmak için şans."
							},
							"Key": "Fountain"
						},
						{
							"Source": {
								"Text": "Chance to find a bonus spin wheel on the map."
							},
							"Translation": {
								"Text": "Haritada bir bonus spin tekerleği bulma şansı."
							},
							"Key": "SpinWheel"
						},
						{
							"Source": {
								"Text": "Chance to find a treasure chest on the map."
							},
							"Translation": {
								"Text": "Haritada bir hazine göğsü bulma şansı."
							},
							"Key": "TreasureChest"
						},
						{
							"Source": {
								"Text": "Chance to heal when dealing damage to enemies."
							},
							"Translation": {
								"Text": "Düşmanlara zarar verirken iyileşme şansı."
							},
							"Key": "LifeSteal"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when reflecting damage."
							},
							"Translation": {
								"Text": "Hasarı yansıtan bir düşmanı anında öldürme şansı."
							},
							"Key": "Crush"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when you dodge their attack."
							},
							"Translation": {
								"Text": "Saldırılarını yaparken anında bir düşmanı öldürme şansı."
							},
							"Key": "Assassinate"
						},
						{
							"Source": {
								"Text": "Chance to reflect incoming damage back at the attacker."
							},
							"Translation": {
								"Text": "Gelen hasarları saldırganda yansıtacak şans."
							},
							"Key": "ReflectDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier applied on critical hits. 1.5 = 50% bonus damage."
							},
							"Translation": {
								"Text": "Hasar çokplier kritik vuruşlarda uygulanır. 1.5 = %50 bonus hasar."
							},
							"Key": "CritDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at close range."
							},
							"Translation": {
								"Text": "Yakın aralıkta düşmanlara saldıran çok basit bir hasar."
							},
							"Key": "CloseRangeDmg"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at long range."
							},
							"Translation": {
								"Text": "Düşmanlara uzun menzilde saldırdığında çok basit bir hasar."
							},
							"Key": "LongRangeDmg"
						},
						{
							"Source": {
								"Text": "Health points regenerated per second."
							},
							"Translation": {
								"Text": "Sağlık noktaları ikinci olarak yeniden üretilir."
							},
							"Key": "HpRegen"
						},
						{
							"Source": {
								"Text": "Hero movement speed multiplier. Higher values let you move faster across the map."
							},
							"Translation": {
								"Text": "Kahraman hareketi hızı çok basit. Yüksek değerler haritada daha hızlı hareket etmenize izin verir."
							},
							"Key": "Speed"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Hitbox boyut bonus alanı-of- effects saldırıları için."
							},
							"Key": "AoeScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Projek atakları için Hitbox büyüklüğü bonus."
							},
							"Key": "BounceScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Hasar zamanı etkileri için Hitbox büyüklüğü bonus."
							},
							"Key": "DotScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Piercing saldırıları için Hitbox büyüklüğü bonus."
							},
							"Key": "PierceScale"
						},
						{
							"Source": {
								"Text": "How quickly your hero attacks. Higher values reduce the interval between attacks."
							},
							"Translation": {
								"Text": "Kahraman saldırılarınız ne kadar çabuk. Yüksek değerler saldırılar arasındaki aralığı azaltır."
							},
							"Key": "AttackSpeed"
						},
						{
							"Source": {
								"Text": "Improves chances for rare item drops, spin-wheel bonuses, and world event spawns."
							},
							"Translation": {
								"Text": "Nadir eşya damlaları, spin-wheel bonusları ve dünya olayı spawns için şansları geliştirin."
							},
							"Key": "Luck"
						},
						{
							"Source": {
								"Text": "Improves the odds of higher-rarity rewards when opening a crate."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "LootCrate"
						},
						{
							"Source": {
								"Text": "Maximum distance your attacks can reach."
							},
							"Translation": {
								"Text": "Saldırılarınızın en fazla mesafe ulaşabilir."
							},
							"Key": "AttackRange"
						},
						{
							"Source": {
								"Text": "Reduces incoming damage from all sources. Each point subtracts flat damage before HP loss."
							},
							"Translation": {
								"Text": "Tüm kaynaklardan gelen zararları azaltır. Her nokta HP kaybından önce düz hasar alır."
							},
							"Key": "Armor"
						},
						{
							"Source": {
								"Text": "Size multiplier for your attack hitbox. Larger scale hits more enemies per swing."
							},
							"Translation": {
								"Text": "Saldırınız hitbox için çokplier. Büyük ölçek hızla daha fazla düşman vurur."
							},
							"Key": "AttackScale"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to cheat at the Gambler."
							},
							"Translation": {
								"Text": "Gambler'de aldatmaya çalışırken başarı şansı."
							},
							"Key": "Cheating"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to steal from the Vendor."
							},
							"Translation": {
								"Text": "Satıcıdan çalmaya çalışırken başarı şansı."
							},
							"Key": "Stealing"
						},
						{
							"Source": {
								"Text": "Your hero's current level. Gain XP by killing enemies to level up and improve your stats."
							},
							"Translation": {
								"Text": "Kahramanınızın mevcut seviyesi. Düşmanları seviyelemek ve istatistiklerinizi geliştirmek için XP'yi alın."
							},
							"Key": "Level"
						}
					]
				},
