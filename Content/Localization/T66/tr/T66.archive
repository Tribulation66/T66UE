				{
					"Namespace": "HeroQuotes",
					"Children": [
						{
							"Source": {
								"Text": "\"Bite back.\""
							},
							"Translation": {
								"Text": "\"Bite geri döndü.\""
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "\"Catch me first.\""
							},
							"Translation": {
								"Text": "“İlk önce beni ele alalım.”"
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "\"Cold wins.\""
							},
							"Translation": {
								"Text": "\"Cold kazanır.\""
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "\"Directive: survive.\""
							},
							"Translation": {
								"Text": "\"Doğru: hayatta kal.\""
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "\"Embrace the venom.\""
							},
							"Translation": {
								"Text": "\"Onu çirkin yapalım.\""
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "\"Fast hands, faster kill.\""
							},
							"Translation": {
								"Text": "\"Hızlı eller, daha hızlı öldür.\""
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "\"For honor.\""
							},
							"Translation": {
								"Text": "Fırtına itaat eder.”"
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "\"Gold outlasts gods.\""
							},
							"Translation": {
								"Text": "\"Altın tanrılar.\""
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "\"Hold the line.\""
							},
							"Translation": {
								"Text": "\"Köpürücüyü öldürdü.\""
							},
							"Key": "Hero_1"
						},
						{
							"Source": {
								"Text": "\"It gets worse.\""
							},
							"Translation": {
								"Text": "\"Daha kötüleşiyor.\""
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "\"Kneel to thunder.\""
							},
							"Translation": {
								"Text": "\"Kneel'in yanına.\""
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "\"Send it.\""
							},
							"Translation": {
								"Text": "\"Onu gönder.\""
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "\"Stay sharp.\""
							},
							"Translation": {
								"Text": "\"Stay keskin.\""
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "\"Strike true.\""
							},
							"Translation": {
								"Text": "\"Benim için daha önce."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "\"Unlucky for them.\""
							},
							"Translation": {
								"Text": "\"Onlar için şanssız.\""
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "\"You won't see dawn.\""
							},
							"Translation": {
								"Text": "\"Sen şafak görmeyeceksin.\""
							},
							"Key": "Hero_11"
						}
					]
				},
