				{
					"Namespace": "Tutorial",
					"Children": [
						{
							"Source": {
								"Text": "Items have primary stat lines but might have more."
							},
							"Translation": {
								"Text": "Los artículos tienen líneas primarias pero podrían tener más."
							},
							"Key": "Step_ItemsExplain"
						},
						{
							"Source": {
								"Text": "Space bar for jump"
							},
							"Translation": {
								"Text": "Barra de espacio para saltar"
							},
							"Key": "Step_Jump"
						},
						{
							"Source": {
								"Text": "That bag has an item press f to pick it up"
							},
							"Translation": {
								"Text": "Esa bolsa tiene una prensa para recogerla."
							},
							"Key": "Step_PickupBag"
						},
						{
							"Source": {
								"Text": "ULT with R when you need extra power"
							},
							"Translation": {
								"Text": "ULT con R cuando necesitas energía extra"
							},
							"Key": "Step_Ult"
						},
						{
							"Source": {
								"Text": "WASD to move"
							},
							"Translation": {
								"Text": "WASD to move"
							},
							"Key": "Step_Move"
						},
						{
