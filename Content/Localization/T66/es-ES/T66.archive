				{
					"Namespace": "CompanionLore",
					"Children": [
						{
							"Source": {
								"Text": "A cunning trickster with a heart of gold."
							},
							"Translation": {
								"Text": "Un tramposo con un corazón de oro."
							},
							"Key": "Companion_05"
						},
						{
							"Source": {
								"Text": "A mysterious companion."
							},
							"Translation": {
								"Text": "Un compañero misterioso."
							},
							"Key": "Unknown"
						},
						{
							"Source": {
								"Text": "A steadfast guardian who never leaves your side."
							},
							"Translation": {
								"Text": "Un guardián firme que nunca deja tu lado."
							},
							"Key": "Companion_01"
						},
						{
							"Source": {
								"Text": "Born in flames, she heals through sheer willpower."
							},
							"Translation": {
								"Text": "Nacida en llamas, sana a través de una fuerza de voluntad pura."
							},
							"Key": "Companion_02"
						},
						{
							"Source": {
								"Text": "Draws strength from moonlight to shield allies."
							},
							"Translation": {
								"Text": "Dibuja fuerza de la luz de la luna para proteger a los aliados."
							},
							"Key": "Companion_06"
						},
						{
							"Source": {
								"Text": "Forged in the depths, tempered by tribulation."
							},
							"Translation": {
								"Text": "Forjado en las profundidades, templado por la tribulación."
							},
							"Key": "Companion_07"
						},
						{
							"Source": {
								"Text": "Loner Style"
							},
							"Translation": {
								"Text": "Loner Style"
							},
							"Key": "NoCompanion"
						},
						{
							"Source": {
								"Text": "No lore available."
							},
							"Translation": {
								"Text": "No hay nada disponible."
							},
							"Key": "FallbackLore"
						},
						{
							"Source": {
								"Text": "Once a wanderer, now sworn to protect the fallen."
							},
							"Translation": {
								"Text": "Una vez un vagabundo, ahora juró proteger a los caídos."
							},
							"Key": "Companion_03"
						},
						{
							"Source": {
								"Text": "The last of her kind, fighting to survive."
							},
							"Translation": {
								"Text": "La última de su clase, luchando por sobrevivir."
							},
							"Key": "Companion_08"
						},
						{
							"Source": {
								"Text": "Whispers ancient prayers that mend broken bones."
							},
							"Translation": {
								"Text": "Susurra oraciones antiguas que semen huesos rotos."
							},
							"Key": "Companion_04"
						}
					]
				},
