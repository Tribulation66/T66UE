				{
					"Namespace": "StatTooltips",
					"Children": [
						{
							"Source": {
								"Text": "A unique casino token that improves item sell prices. Higher levels push the sell rate up to 100%."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "GamblerToken"
						},
						{
							"Source": {
								"Text": "Aggro generation multiplier. Higher values draw more enemy attention."
							},
							"Translation": {
								"Text": "Multiplicador de generación Aggro. Los valores superiores atraen más atención enemiga."
							},
							"Key": "Taunt"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Bono de velocidad de ataque para ataques de área de efecto."
							},
							"Key": "AoeSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Bono de velocidad de ataque para rebotar ataques proyectiles."
							},
							"Key": "BounceSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Ataque la bonificación de velocidad para los efectos de daño a tiempo extra."
							},
							"Key": "DotSpeed"
						},
						{
							"Source": {
								"Text": "Attack speed bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Bono de velocidad de ataque para perforar ataques."
							},
							"Key": "PierceSpeed"
						},
						{
							"Source": {
								"Text": "Base damage dealt by each attack. Increased by items and level-ups."
							},
							"Translation": {
								"Text": "Daño de base tratado por cada ataque. Aumento por elementos y niveles."
							},
							"Key": "Damage"
						},
						{
							"Source": {
								"Text": "Bonus damage for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Daño de bonificación por ataques de área de efecto."
							},
							"Key": "AoeDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Daños por bonificación de ataques proyectiles."
							},
							"Key": "BounceDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for damage-over-time effects."
							},
							"Translation": {
								"Text": "Daño de bonificación por efectos de daño a tiempo extra."
							},
							"Key": "DotDamage"
						},
						{
							"Source": {
								"Text": "Bonus damage for piercing attacks that pass through enemies."
							},
							"Translation": {
								"Text": "Daño de bonificación por ataques perforantes que pasan a través de enemigos."
							},
							"Key": "PierceDamage"
						},
						{
							"Source": {
								"Text": "Bonus movement speed multiplier from secondary stat sources."
							},
							"Translation": {
								"Text": "Multiplicador de velocidad de movimiento de bonificación de fuentes secundarias."
							},
							"Key": "MovementSpeed"
						},
						{
							"Source": {
								"Text": "Chance for each attack to land a critical hit."
							},
							"Translation": {
								"Text": "La oportunidad de cada ataque para aterrizar un golpe crítico."
							},
							"Key": "CritChance"
						},
						{
							"Source": {
								"Text": "Chance to completely dodge an incoming attack. Also unlocks evasion-based secondary stats."
							},
							"Translation": {
								"Text": "La oportunidad de esquivar completamente un ataque entrante. También desbloquea estadísticas secundarias basadas en evasión."
							},
							"Key": "Evasion"
						},
						{
							"Source": {
								"Text": "Chance to confuse enemies on hit, making them lose track of you."
							},
							"Translation": {
								"Text": "La oportunidad de confundir enemigos en golpe, haciendo que pierdan la pista de usted."
							},
							"Key": "Invisibility"
						},
						{
							"Source": {
								"Text": "Chance to counter-attack when dodging an enemy's attack."
							},
							"Translation": {
								"Text": "La oportunidad de contraatacar al atacar a un enemigo."
							},
							"Key": "CounterAttack"
						},
						{
							"Source": {
								"Text": "Chance to encounter a gold-dropping goblin."
							},
							"Translation": {
								"Text": "La oportunidad de encontrar un duende de oro."
							},
							"Key": "Goblin"
						},
						{
							"Source": {
								"Text": "Chance to encounter a leprechaun with bonus rewards."
							},
							"Translation": {
								"Text": "La oportunidad de encontrar un duende con recompensas de bonificación."
							},
							"Key": "Leprechaun"
						},
						{
							"Source": {
								"Text": "Chance to find a Fountain of Life that restores health."
							},
							"Translation": {
								"Text": "La oportunidad de encontrar una Fuente de Vida que restaura la salud."
							},
							"Key": "Fountain"
						},
						{
							"Source": {
								"Text": "Chance to find a bonus spin wheel on the map."
							},
							"Translation": {
								"Text": "La oportunidad de encontrar una rueda de giro de bonificación en el mapa."
							},
							"Key": "SpinWheel"
						},
						{
							"Source": {
								"Text": "Chance to find a treasure chest on the map."
							},
							"Translation": {
								"Text": "La oportunidad de encontrar un tesoro en el mapa."
							},
							"Key": "TreasureChest"
						},
						{
							"Source": {
								"Text": "Chance to heal when dealing damage to enemies."
							},
							"Translation": {
								"Text": "La oportunidad de sanar cuando se trata de daños a los enemigos."
							},
							"Key": "LifeSteal"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when reflecting damage."
							},
							"Translation": {
								"Text": "La oportunidad de matar instantáneamente a un enemigo cuando refleja el daño."
							},
							"Key": "Crush"
						},
						{
							"Source": {
								"Text": "Chance to instantly kill an enemy when you dodge their attack."
							},
							"Translation": {
								"Text": "La oportunidad de matar instantáneamente a un enemigo cuando usted esquiva su ataque."
							},
							"Key": "Assassinate"
						},
						{
							"Source": {
								"Text": "Chance to reflect incoming damage back at the attacker."
							},
							"Translation": {
								"Text": "La oportunidad de reflejar el daño entrante en el atacante."
							},
							"Key": "ReflectDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier applied on critical hits. 1.5 = 50% bonus damage."
							},
							"Translation": {
								"Text": "Multiplicador de daños aplicado en golpes críticos. 1,5 = 50% de daño extra."
							},
							"Key": "CritDamage"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at close range."
							},
							"Translation": {
								"Text": "Multiplicador de daño cuando ataca a enemigos a corta distancia."
							},
							"Key": "CloseRangeDmg"
						},
						{
							"Source": {
								"Text": "Damage multiplier when attacking enemies at long range."
							},
							"Translation": {
								"Text": "Multiplicador de daño al atacar enemigos a largo plazo."
							},
							"Key": "LongRangeDmg"
						},
						{
							"Source": {
								"Text": "Health points regenerated per second."
							},
							"Translation": {
								"Text": "Puntos de salud regenerados por segundo."
							},
							"Key": "HpRegen"
						},
						{
							"Source": {
								"Text": "Hero movement speed multiplier. Higher values let you move faster across the map."
							},
							"Translation": {
								"Text": "Multiplicador de velocidad de movimiento del héroe. Valores más altos le permiten moverse más rápido a través del mapa."
							},
							"Key": "Speed"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for area-of-effect attacks."
							},
							"Translation": {
								"Text": "Bonificación de tamaño de caja para ataques de área de efecto."
							},
							"Key": "AoeScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for bouncing projectile attacks."
							},
							"Translation": {
								"Text": "Bonificación de tamaño Hitbox para rebotar ataques proyectiles."
							},
							"Key": "BounceScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for damage-over-time effects."
							},
							"Translation": {
								"Text": "Bonificación del tamaño de la caja para los efectos del daño-sobre-tiempo."
							},
							"Key": "DotScale"
						},
						{
							"Source": {
								"Text": "Hitbox size bonus for piercing attacks."
							},
							"Translation": {
								"Text": "Bonificación de tamaño Hitbox para los ataques de perforación."
							},
							"Key": "PierceScale"
						},
						{
							"Source": {
								"Text": "How quickly your hero attacks. Higher values reduce the interval between attacks."
							},
							"Translation": {
								"Text": "Qué rápido ataca tu héroe. Los valores superiores reducen el intervalo entre los ataques."
							},
							"Key": "AttackSpeed"
						},
						{
							"Source": {
								"Text": "Improves chances for rare item drops, spin-wheel bonuses, and world event spawns."
							},
							"Translation": {
								"Text": "Mejora las oportunidades para las gotas de artículos raras, bonificaciones de la rueda de giro, y los resultados del evento mundial."
							},
							"Key": "Luck"
						},
						{
							"Source": {
								"Text": "Improves the odds of higher-rarity rewards when opening a crate."
							},
							"Translation": {
								"Text": ""
							},
							"Key": "LootCrate"
						},
						{
							"Source": {
								"Text": "Maximum distance your attacks can reach."
							},
							"Translation": {
								"Text": "Distancia máxima tus ataques pueden alcanzar."
							},
							"Key": "AttackRange"
						},
						{
							"Source": {
								"Text": "Reduces incoming damage from all sources. Each point subtracts flat damage before HP loss."
							},
							"Translation": {
								"Text": "Reduce los daños recibidos de todas las fuentes. Cada punto resta daño plano antes de la pérdida de HP."
							},
							"Key": "Armor"
						},
						{
							"Source": {
								"Text": "Size multiplier for your attack hitbox. Larger scale hits more enemies per swing."
							},
							"Translation": {
								"Text": "Multiplicador de tamaño para su caja de ataque. La escala más grande golpea a más enemigos por swing."
							},
							"Key": "AttackScale"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to cheat at the Gambler."
							},
							"Translation": {
								"Text": "La oportunidad de éxito al intentar engañar al jugador."
							},
							"Key": "Cheating"
						},
						{
							"Source": {
								"Text": "Success chance when attempting to steal from the Vendor."
							},
							"Translation": {
								"Text": "La oportunidad de éxito al intentar robar del vendedor."
							},
							"Key": "Stealing"
						},
						{
							"Source": {
								"Text": "Your hero's current level. Gain XP by killing enemies to level up and improve your stats."
							},
							"Translation": {
								"Text": "El nivel actual de tu héroe. Ganar XP matando enemigos para nivelar y mejorar sus estadísticas."
							},
							"Key": "Level"
						}
					]
				},
