				{
					"Namespace": "IdolAltar",
					"Children": [
						{
							"Source": {
								"Text": "ACID"
							},
							"Translation": {
								"Text": "ACID"
							},
							"Key": "Idol_Acid_Name"
						},
						{
							"Source": {
								"Text": "ACID\nDissolves enemies with damage over time."
							},
							"Translation": {
								"Text": "ACID\nการ กําจัด ศัตรู"
							},
							"Key": "Idol_Acid_Tooltip"
						},
						{
							"Source": {
								"Text": "AOE"
							},
							"Translation": {
								"Text": "อาโออี"
							},
							"Key": "Category_AOE"
						},
						{
							"Source": {
								"Text": "All idol slots are full."
							},
							"Translation": {
								"Text": "ไอดอลทุกช่องเต็มหมดแล้ว"
