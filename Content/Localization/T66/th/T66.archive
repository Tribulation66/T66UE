							},
							"Key": "Idol_Lava_Tooltip"
						},
						{
							"Source": {
								"Text": "LIGHT"
							},
							"Translation": {
								"Text": "ความสว่าง"
							},
							"Key": "Idol_Light_Name"
						},
						{
							"Source": {
								"Text": "LIGHT\nAn idol of radiant power."
							},
							"Translation": {
								"Text": "ความสว่าง\nเทวรูปแห่งพลังแสง"
