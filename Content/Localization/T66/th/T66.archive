							},
							"Translation": {
								"Text": "ทิ้งไอดอลไว้ที่นี่"
							},
							"Key": "DropAnIdolHere"
						},
						{
							"Source": {
								"Text": "EARTH"
							},
							"Translation": {
								"Text": "พื้น ผิว"
							},
							"Key": "Idol_Earth_Name"
						},
						{
							"Source": {
								"Text": "EARTH\nTriggers a shockwave at the point of impact."
							},
							"Translation": {
								"Text": "พื้น ผิว\nทําให้เกิดแรงกระแทกที่จุดปะทะ"
							},
							"Key": "Idol_Earth_Tooltip"
						},
						{
							"Source": {
								"Text": "ELECTRIC"
							},
							"Translation": {
								"Text": "อิเล็กตรอน"
							},
							"Key": "Idol_Electric_Name"
						},
						{
							"Source": {
								"Text": "ELECTRIC\nSends a bolt that bounces between enemies."
							},
							"Translation": {
								"Text": "อิเล็กตรอน\nส่งสายฟ้าที่เด้งระหว่างศัตรู"
							},
							"Key": "Idol_Electric_Tooltip"
						},
						{
							"Source": {
								"Text": "Equipped."
							},
							"Translation": {
								"Text": "ปลดปล่อย"
							},
							"Key": "Equipped"
						},
						{
							"Source": {
								"Text": "FIRE"
							},
							"Translation": {
								"Text": "ยิง"
							},
							"Key": "Idol_Fire_Name"
						},
						{
							"Source": {
								"Text": "FIRE\nAuto attacks apply a burn: 10 damage per second."
							},
							"Translation": {
								"Text": "ยิง\nการโจมตีอัตโนมัติใช้ไฟเผา: 10 ความเสียหายต่อวินาที"
							},
							"Key": "Idol_Fire_Tooltip"
						},
						{
							"Source": {
								"Text": "GLASS"
							},
							"Translation": {
								"Text": "คลาส"
							},
							"Key": "Idol_Glass_Name"
						},
						{
							"Source": {
								"Text": "GLASS\nSends a glass shard that pierces through enemies."
							},
							"Translation": {
								"Text": "คลาส\nส่งเศษแก้วที่ทะลุผ่านศัตรู"
							},
							"Key": "Idol_Glass_Tooltip"
						},
						{
							"Source": {
