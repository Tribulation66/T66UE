							"Translation": {
								"Text": "เติมเต็ม"
							},
							"Key": "Idol_Bleed_Name"
						},
						{
							"Source": {
								"Text": "BLEED\nCauses enemies to bleed over time."
							},
							"Translation": {
								"Text": "เติมเต็ม\nส่งผลให้ศัตรูต้องหลั่งเลือด"
							},
							"Key": "Idol_Bleed_Tooltip"
						},
						{
							"Source": {
								"Text": "BONE"
							},
							"Translation": {
								"Text": "เดี่ยว"
							},
							"Key": "Idol_Bone_Name"
						},
						{
							"Source": {
								"Text": "BONE\nFires a bone spear that pierces through enemies."
							},
							"Translation": {
								"Text": "เดี่ยว\nยิงหอกปักกระดูก ที่แทงศัตรู"
							},
							"Key": "Idol_Bone_Tooltip"
						},
						{
							"Source": {
								"Text": "Bounce"
							},
							"Translation": {
								"Text": "กระเด้งกระดอน"
							},
							"Key": "Category_Bounce"
						},
						{
							"Source": {
								"Text": "CURSE"
							},
							"Translation": {
								"Text": "นก กระสา"
							},
							"Key": "Idol_Curse_Name"
						},
						{
							"Source": {
								"Text": "CURSE\nApplies a damaging curse over time."
							},
							"Translation": {
								"Text": "นก กระสา\nใช้คําสาปทําลายในเวลา"
							},
							"Key": "Idol_Curse_Tooltip"
						},
						{
							"Source": {
								"Text": "DECAY"
							},
							"Translation": {
								"Text": "DECAY"
							},
							"Key": "Idol_Decay_Name"
						},
						{
							"Source": {
								"Text": "DECAY\nRots enemies with damage over time."
							},
							"Translation": {
								"Text": "DECAY\nศัตรูที่ถูกทําลายเมื่อเวลาผ่านไป"
