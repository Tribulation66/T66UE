							"Translation": {
								"Text": "เตรียมเรียบร้อยแล้ว"
							},
							"Key": "AlreadyEquipped"
						},
						{
							"Source": {
								"Text": "BLACK HOLE"
							},
							"Translation": {
								"Text": "สีเขียว"
							},
							"Key": "Idol_BlackHole_Name"
						},
						{
							"Source": {
								"Text": "BLACK HOLE\nOpens a void at the point of impact."
							},
							"Translation": {
								"Text": "สีเขียว\nเปิดช่องว่างที่จุดของผลกระทบ"
							},
							"Key": "Idol_BlackHole_Tooltip"
						},
						{
							"Source": {
								"Text": "BLEED"
