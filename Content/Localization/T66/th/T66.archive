							},
							"Translation": {
								"Text": "เพียร์ซ"
							},
							"Key": "Category_Pierce"
						},
						{
							"Source": {
								"Text": "RUBBER"
							},
							"Translation": {
								"Text": "RUBBER"
							},
							"Key": "Idol_Rubber_Name"
						},
