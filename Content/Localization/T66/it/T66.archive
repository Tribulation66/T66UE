				{
					"Namespace": "HeroDescriptions",
					"Children": [
						{
							"Source": {
								"Text": "A chaos-fueled duelist who wins fights by overwhelming the room."
							},
							"Translation": {
								"Text": "Un duellista fuorviato dal caos che vince lotte schiacciando la stanza."
							},
							"Key": "Hero_12"
						},
						{
							"Source": {
								"Text": "A cold-eyed wanderer hardened by long roads and worse winters."
							},
							"Translation": {
								"Text": "Un vagabondo dagli occhi freddi indurito da lunghe strade e inverni peggiori."
							},
							"Key": "Hero_14"
						},
						{
							"Source": {
								"Text": "A deadpan menace who walks into disaster without blinking."
							},
							"Translation": {
								"Text": "Una minaccia mortale che entra in disastro senza lampeggiare."
							},
							"Key": "Hero_13"
						},
						{
							"Source": {
								"Text": "A disciplined duelist with a steady hand and colder nerve."
							},
							"Translation": {
								"Text": "Un duellista disciplinato con una mano costante e nervo più freddo."
							},
							"Key": "Hero_5"
						},
						{
							"Source": {
								"Text": "A grim scavenger king draped in dust, gold, and bad omens."
							},
							"Translation": {
								"Text": "Un re spaventoso del cacciatorpediniere si è intorpidito in polvere, oro e cattivi presagi."
							},
							"Key": "Hero_15"
						},
						{
							"Source": {
								"Text": "A loyal brawler who charges first and doubts later."
							},
							"Translation": {
								"Text": "Un brawler leale che accusa prima e poi dubbi."
							},
							"Key": "Hero_10"
						},
						{
							"Source": {
								"Text": "A nimble trickster who never stays where danger lands."
							},
							"Translation": {
								"Text": "Un agile imbroglione che non rimane mai dove il pericolo atterra."
							},
							"Key": "Hero_9"
						},
						{
							"Source": {
								"Text": "A quick-draw outlaw who turns panic into momentum."
							},
							"Translation": {
								"Text": "Un fuorilegge che trasforma il panico in slancio."
							},
							"Key": "Hero_8"
						},
						{
							"Source": {
								"Text": "A relentless machine built to keep marching through the swarm."
							},
							"Translation": {
								"Text": "Una macchina implacabile costruita per continuare a marciare attraverso lo sciame."
							},
							"Key": "Hero_7"
						},
						{
							"Source": {
								"Text": "A silent hunter who lets the dark speak for him."
							},
							"Translation": {
								"Text": "Un cacciatore silenzioso che lascia parlare il buio per lui."
							},
							"Key": "Hero_11"
						},
						{
							"Source": {
								"Text": "A storm-crowned tyrant who fights like thunder made flesh."
							},
							"Translation": {
								"Text": "Un tiranno tempestato che combatte come un tuono fatto carne."
							},
							"Key": "Hero_6"
						},
						{
							"Source": {
								"Text": "A stubborn survivor who drags every doomed run across the line."
							},
							"Translation": {
								"Text": "Una sopravvissuta testardo che trascina tutti i condannati correre attraverso la linea."
							},
							"Key": "Hero_16"
						},
						{
							"Source": {
								"Text": "DOT and evasion. Poison and strike."
							},
							"Translation": {
								"Text": "Un bruiser di strada che prospera quando la lotta diventa disordinata."
							},
							"Key": "Hero_4"
						},
						{
							"Source": {
								"Text": "Fast bouncer. Chains to multiple foes."
							},
							"Translation": {
								"Text": "Un signore della guerra che rompe le linee nemiche attraverso una forza pura."
							},
							"Key": "Hero_3"
						},
						{
							"Source": {
								"Text": "Select a hero to view their description."
							},
							"Translation": {
								"Text": "Selezionare un eroe per visualizzare la loro descrizione."
							},
							"Key": "SelectHeroPrompt"
						},
						{
							"Source": {
								"Text": "Steadfast knight. Ready for battle."
							},
							"Translation": {
								"Text": "Un vecchio stregone la cui calma nasconde il potere terrificante."
							},
							"Key": "Hero_2"
						},
						{
							"Source": {
								"Text": "Sturdy frontline. Favors armor."
							},
							"Translation": {
								"Text": "Sturdy frontline. Favorisce l'armatura."
							},
							"Key": "Hero_1"
						}
					]
				},
