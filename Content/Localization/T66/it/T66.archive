				{
					"Namespace": "Tutorial",
					"Children": [
						{
							"Source": {
								"Text": "Items have primary stat lines but might have more."
							},
							"Translation": {
								"Text": "Gli articoli hanno linee di statistiche primarie, ma potrebbero avere di più."
							},
							"Key": "Step_ItemsExplain"
						},
						{
							"Source": {
								"Text": "Space bar for jump"
							},
							"Translation": {
								"Text": "Barra spaziatrice per salto"
							},
							"Key": "Step_Jump"
						},
						{
							"Source": {
								"Text": "That bag has an item press f to pick it up"
