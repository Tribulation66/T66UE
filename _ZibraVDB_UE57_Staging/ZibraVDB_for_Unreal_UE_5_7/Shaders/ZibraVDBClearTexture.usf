RWTexture3D<float3> SparseEmission;
RWTexture3D<float> SparseDensity;

[numthreads(8, 8, 8)]
void ClearEmissionAndDensity(uint3 id : SV_DispatchThreadID, uint3 gtid : SV_GroupThreadID, uint3 gid : SV_GroupID)
{
    SparseEmission[id] = 0.0f;
    SparseDensity[id] = 0.0f;
}